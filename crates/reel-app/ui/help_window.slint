import { HorizontalBox, ScrollView, VerticalBox } from "std-widgets.slint";

export component HelpWindow inherits Window {
    preferred-width: 560px;
    preferred-height: 640px;
    icon: @image-url("assets/knotreels.png");

    in property <string> help-title: "Reel — Help";
    title: root.help-title;

    in property <styled-text> body-text: @markdown("");

    VerticalBox {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 12px;
        padding-bottom: 0;
        spacing: 10px;
        HorizontalBox {
            min-height: 100px;
            vertical-stretch: 0;
            alignment: center;
            Image {
                width: 300px;
                height: 165px;
                source: @image-url("assets/knotreels.png");
                image-fit: contain;
            }
        }
        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            width: 100%;
            VerticalBox {
                padding-bottom: 12px;
                StyledText {
                    text: root.body-text;
                    width: 100%;
                }
            }
        }
    }
}
