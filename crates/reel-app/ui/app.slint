import { Button, Slider, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    preferred-width: 960px;
    preferred-height: 600px;
    title: "Reel";

    // Inputs from Rust
    in property <image> current-frame;
    in property <float> duration-ms: 0;
    in property <float> playhead-ms: 0;
    in property <bool> is-playing: false;
    in property <string> status-text: "Ready";

    // Callbacks fired to Rust
    callback open-file();
    callback play-pause();
    callback seek(float /* pts_ms */);

    VerticalBox {
        spacing: 0px;
        padding: 0px;

        // Video viewport — letterboxed, fills as much of the window as the
        // layout allows.
        Rectangle {
            background: #000;
            vertical-stretch: 1;
            Image {
                source: root.current-frame;
                image-fit: contain;
                width: parent.width;
                height: parent.height;
            }
        }

        // Timeline stub — full-width strip.
        Rectangle {
            background: #1e1e22;
            height: 64px;
            Text {
                text: "timeline";
                color: #666;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Transport bar.
        Rectangle {
            background: #2a2a30;
            height: 56px;
            HorizontalBox {
                padding: 8px;
                spacing: 8px;
                alignment: center;

                Button {
                    text: "Open…";
                    clicked => { root.open-file(); }
                }
                Button {
                    text: root.is-playing ? "Pause" : "Play";
                    clicked => { root.play-pause(); }
                }
                Slider {
                    minimum: 0;
                    maximum: max(root.duration-ms, 1);
                    value: root.playhead-ms;
                    changed(v) => { root.seek(v); }
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.status-text;
                    color: #ccc;
                    vertical-alignment: center;
                }
            }
        }
    }
}
