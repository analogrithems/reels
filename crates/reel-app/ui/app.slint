import { HelpWindow } from "help_window.slint";
import { Theme } from "theme.slint";
import { Button, ComboBox, HorizontalBox, LineEdit, Slider, VerticalBox } from "std-widgets.slint";

export { HelpWindow }

/// One segment in a filmstrip row (file name + proportional width from clip duration).
///
/// `is-video` and `is-subtitle` are mutually exclusive. When both are `false`
/// the chip is assumed to be **audio**. The split lets the lane styler pick
/// the correct token from [`Theme`] (clip-video / clip-audio / clip-subtitle)
/// without threading a separate `kind: int` through the Rust side.
///
/// `clip-id` is the UUID of the backing `reel_core::project::Clip` (hyphenated
/// string), or `""` for synthetic full-width chips generated for single-media
/// container-stream lanes (U2-c: those are **not** draggable; real edits route
/// through the project's `clip_ids`). `begin-ms` / `end-ms` are the clip's
/// current `in_point`/`out_point` in source milliseconds (U2-c trim-handles
/// clamp against them). `source-duration-ms` caps the right handle — `0` when
/// the probe didn't report a duration ("unknown"; upper bound skipped, same
/// policy as `session::trim_clip`).
export struct TlChip {
    label: string,
    width-weight: float,
    chip-idx: int,
    is-video: bool,
    is-subtitle: bool,
    clip-id: string,
    // Absolute source-media path. Populated for both real project
    // clips and synthetic single-media chips — the latter have an
    // empty `clip-id` (no backing editable Clip) but still have a
    // decodeable source, and preview gates key on this field so they
    // render in either mode.
    source-path: string,
    begin-ms: int,
    end-ms: int,
    source-duration-ms: int,
    // Preview rasters supplied by the Rust-side AssetCache. `waveform`
    // is populated on audio chips (per-column min/max peaks) and
    // `thumbnails` on video chips (evenly-spaced frame strip). The
    // `*-ready` flags gate swap-in: while false the chip body shows a
    // diagonal-stripe placeholder so the timeline renders **instantly**
    // on media load and the real image fades in as the background
    // worker finishes decoding. Subtitle chips use neither (flat fill).
    waveform: image,
    waveform-ready: bool,
    thumbnails: image,
    thumbnails-ready: bool,
}

/// Single timeline lane: label column + chip strip (or empty state).
///
/// v0 mock: each lane pill carries a colored **kind indicator** (a 4-px tall
/// bar on the left edge) so the lane type reads at a glance even when the
/// chips row is empty. Caller sets `lane-accent` to the matching `Theme`
/// token (clip-video / clip-audio / clip-subtitle).
///
/// Trash appears on row hover (`group/track`); gated by `delete-enabled`
/// (e.g. last video lane).
component FilmstripLane inherits VerticalBox {
    in property <string> lane-label;
    in property <color> lane-accent: Theme.text-tertiary;
    in property <[TlChip]> chips;
    in property <bool> delete-enabled: true;
    /// Diagonal-stripe image shown on audio chips whose `waveform` hasn't
    /// arrived from the AssetCache yet. Piped in from `AppWindow` so the
    /// same raster is shared across every lane.
    in property <image> placeholder-stripe;
    /// Current playhead as a fraction of total duration (0..=1). Drives the
    /// red vertical playhead line overlaid on the lane body so every lane
    /// (video / audio / subtitle) reads the same play position at a glance.
    in property <float> playhead-ratio: 0;
    callback track-delete();
    /// U2-c: edge-drag trim commit. `edge` is 0 (left = in_point) or 1
    /// (right = out_point). `delta-ratio` is the drag distance as a fraction
    /// of the chip's current rendered width — the Rust side multiplies by the
    /// chip's current `(end_ms - begin_ms)` to get a source-ms delta and then
    /// delegates to `session::trim_clip`. `delta-ratio` can be negative (drag
    /// left) or exceed ±1 (drag past the chip) — invariants are enforced in
    /// `trim_clip`, so out-of-range deltas just surface as a "trim failed"
    /// status message with no mutation.
    callback clip-trim-commit(string /* clip-id */, int /* edge */, float /* delta-ratio */);
    /// Click-to-seek. Emitted when the user clicks anywhere on the lane
    /// body outside a trim handle. `ratio` is the click's x-position as a
    /// fraction of the lane body width (0..=1). Caller converts to ms by
    /// multiplying by `duration-ms` and routes to `seek-timeline`. Gated
    /// at the call-site on `media-ready` so empty-lane clicks are no-ops.
    callback seek-ratio(float);
    spacing: 0;
    lane-hover := TouchArea {
        width: 100%;
        HorizontalBox {
            spacing: 8px;
            alignment: stretch;
            padding: 0;
            // v0 mock — left "label column" pill. Darker surface, centered
            // monospace-ish track label, fixed width so all rows align.
            Rectangle {
                width: 44px;
                height: 48px;
                background: Theme.background-secondary;
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.border-subtle;
                clip: true;
                // Colored kind indicator (4-px bar) on the left edge of the
                // pill — mirrors v0's per-kind icon tint without needing three
                // different SVGs at this tiny size.
                Rectangle {
                    width: 4px;
                    height: 100%;
                    x: 0;
                    y: 0;
                    background: root.lane-accent;
                }
                HorizontalBox {
                    alignment: start;
                    padding-left: 8px;
                    padding-right: 0;
                    padding-top: 0;
                    padding-bottom: 0;
                    spacing: 6px;
                    Text {
                        text: root.lane-label;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 600;
                        letter-spacing: 0.5px;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                    }
                }
                // Trash affordance (row-hover, gated by `delete-enabled`): sits
                // flush on the right edge of the label pill, same as v0 mock.
                if lane-hover.has-hover && root.delete-enabled: del-ta := TouchArea {
                    width: 20px;
                    height: 20px;
                    x: parent.width - self.width - 4px;
                    y: (parent.height - self.height) / 2;
                    accessible-role: button;
                    accessible-label: "Delete track";
                    clicked => {
                        root.track-delete();
                    }
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 4px;
                        background: del-ta.has-hover ? #ffffff18 : transparent;
                        Image {
                            width: 12px;
                            height: 12px;
                            x: (parent.width - 12px) / 2;
                            y: (parent.height - 12px) / 2;
                            source: @image-url("icons/lucide/trash-2.svg");
                            colorize: Theme.text-secondary;
                        }
                    }
                }
            }
            // Lane body — holds the clip chips (or empty-state text).
            lane-body := Rectangle {
                horizontal-stretch: 1;
                height: 48px;
                background: Theme.surface-timeline;
                border-radius: 6px;
                border-width: 1px;
                border-color: Theme.border-subtle;
                clip: true;
                // Click-to-seek: covers the entire lane body. Declared first
                // so trim-handle TouchAreas (nested inside chip-rect) and any
                // other inner TouchAreas take priority on overlap. `mouse-x`
                // divided by the lane-body width gives a 0..=1 fraction that
                // the call site multiplies by `duration-ms`.
                seek-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        if (lane-body.width > 0) {
                            root.seek-ratio(max(0.0, min(1.0, self.mouse-x / lane-body.width)));
                        }
                    }
                }
                if root.chips.length == 0: Text {
                    text: "Empty lane";
                    color: Theme.text-tertiary;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                if root.chips.length > 0: HorizontalBox {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    spacing: 3px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    padding-left: 4px;
                    // Reserve a drag-drop strip on the right edge of every
                    // lane so clips don't run flush to the window. Without
                    // this you can't reach "past the last clip" with a
                    // mouse / drop target. ~32 px matches a comfortable
                    // drop-zone hit area on HiDPI screens.
                    padding-right: 32px;
                    // `stretch` lets `horizontal-stretch: item.width-weight` distribute
                    // the lane's full width across chips — so a single-clip lane fills
                    // edge-to-edge and multi-clip lanes still proportion by duration.
                    alignment: stretch;
                    for item in root.chips: chip-rect := Rectangle {
                        horizontal-stretch: item.width-weight;
                        // Lower `min-width` so dense multi-clip lanes fit
                        // within the lane body instead of overflowing past
                        // the window edge (the parent Rectangle has
                        // `clip: true`, which previously *hid* the runoff
                        // rather than reflowing it). 24 px is still wide
                        // enough to reach a trim handle or click-target.
                        min-width: 24px;
                        height: 40px;
                        border-radius: 4px;
                        border-width: 1px;
                        // Border: subtle darker edge per clip-kind so
                        // adjacent chips of the same kind still read as
                        // separate tiles.
                        border-color: item.is-subtitle
                            ? #6b7280
                            : (item.is-video ? #3d6ab0 : #3d8aa8);
                        // Body: Theme tokens, with a light tint on
                        // even-indexed chips so back-to-back tiles of the
                        // same clip still visibly alternate. (Slint has no
                        // `%` so we branch on chip-idx ∈ {0,1}; indices ≥ 2
                        // fall through to the base color, which is fine for
                        // the v0 mock's typical 1–3 tiles per lane.)
                        background: item.is-subtitle
                            ? (item.chip-idx == 1 ? #a6afbd : Theme.clip-subtitle)
                            : (item.is-video
                                ? (item.chip-idx == 1 ? #5e9ee0 : Theme.clip-video)
                                : (item.chip-idx == 1 ? #6dd5ff : Theme.clip-audio));
                        clip: true;
                        // Preview layer: audio chips show a waveform
                        // raster, video chips show a thumbnail strip,
                        // both produced off-thread by AssetCache. Until
                        // the worker finishes we draw the shared
                        // diagonal-stripe placeholder so chips render
                        // **immediately** on media load instead of
                        // waiting for a decode pass. Synthetic (no
                        // clip-id) and subtitle chips stay flat.
                        if item.source-path != "" && !item.is-subtitle && !item.is-video && item.waveform-ready: Image {
                            x: 0;
                            y: 0;
                            width: 100%;
                            height: 100%;
                            source: item.waveform;
                            image-fit: fill;
                        }
                        if item.source-path != "" && !item.is-subtitle && item.is-video && item.thumbnails-ready: Image {
                            x: 0;
                            y: 0;
                            width: 100%;
                            height: 100%;
                            source: item.thumbnails;
                            image-fit: fill;
                        }
                        if item.source-path != "" && !item.is-subtitle && !item.is-video && !item.waveform-ready: Image {
                            x: 0;
                            y: 0;
                            width: 100%;
                            height: 100%;
                            source: root.placeholder-stripe;
                            image-fit: fill;
                            opacity: 0.35;
                        }
                        if item.source-path != "" && !item.is-subtitle && item.is-video && !item.thumbnails-ready: Image {
                            x: 0;
                            y: 0;
                            width: 100%;
                            height: 100%;
                            source: root.placeholder-stripe;
                            image-fit: fill;
                            opacity: 0.35;
                        }
                        // Name overlay: gradient-faded band at the bottom with
                        // the file name, matching v0 `ClipThumbnail` spec.
                        Rectangle {
                            y: parent.height - self.height;
                            height: 16px;
                            width: 100%;
                            background: @linear-gradient(180deg, #00000000 0%, #000000b3 100%);
                            HorizontalBox {
                                padding-left: 6px;
                                padding-right: 6px;
                                padding-top: 0;
                                padding-bottom: 0;
                                alignment: start;
                                Text {
                                    text: item.label;
                                    color: Theme.text-primary;
                                    font-size: 9px;
                                    overflow: elide;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                        // U2-c edge-trim handles. Gated on `clip-id != ""` so
                        // synthetic single-media container-stream chips (which
                        // don't map to an editable Clip) don't expose handles.
                        // Each handle captures the pointer on press; on release
                        // we emit `clip-trim-commit` with the drag distance as
                        // a fraction of the chip's rendered width. Rust applies
                        // it against the chip's begin/end ms and delegates to
                        // `session::trim_clip`, which enforces invariants.
                        if item.clip-id != "": left-trim := TouchArea {
                            x: 0;
                            y: 0;
                            width: 6px;
                            height: parent.height;
                            mouse-cursor: ew-resize;
                            accessible-role: button;
                            accessible-label: "Trim clip start — drag";
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up
                                        && ev.button == PointerEventButton.left
                                        && chip-rect.width > 0) {
                                    root.clip-trim-commit(
                                        item.clip-id,
                                        0,
                                        (self.mouse-x - self.pressed-x) / chip-rect.width,
                                    );
                                }
                            }
                            // Thin vertical accent bar so the handle reads
                            // even when the chip isn't hovered; brightens on
                            // hover so it's obvious the edge is draggable.
                            Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height - 4px;
                                y: 2px;
                                background: left-trim.has-hover ? #ffffffcc : #ffffff40;
                                border-radius: 1px;
                            }
                        }
                        if item.clip-id != "": right-trim := TouchArea {
                            x: parent.width - self.width;
                            y: 0;
                            width: 6px;
                            height: parent.height;
                            mouse-cursor: ew-resize;
                            accessible-role: button;
                            accessible-label: "Trim clip end — drag";
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.up
                                        && ev.button == PointerEventButton.left
                                        && chip-rect.width > 0) {
                                    root.clip-trim-commit(
                                        item.clip-id,
                                        1,
                                        (self.mouse-x - self.pressed-x) / chip-rect.width,
                                    );
                                }
                            }
                            Rectangle {
                                x: parent.width - 2px;
                                width: 2px;
                                height: parent.height - 4px;
                                y: 2px;
                                background: right-trim.has-hover ? #ffffffcc : #ffffff40;
                                border-radius: 1px;
                            }
                        }
                    }
                }
                // Red playhead line — declared last inside the lane body so
                // it paints on top of chip tiles and the empty-state text.
                // `playhead-ratio` is set by the call site to
                // `playhead-ms / duration-ms`, clamped 0..=1.
                Rectangle {
                    x: parent.width * root.playhead-ratio;
                    y: 0;
                    width: 2px;
                    height: parent.height;
                    background: #ff5c5c;
                    visible: root.playhead-ratio >= 0 && root.playhead-ratio <= 1;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1280px;
    preferred-height: 720px;
    title: "Reels";
    background: Theme.background-primary;
    // Logo / window icon: Help window only; macOS Dock uses Reel.app bundle (see `make macos-app`).

    // Video fit: 0 = contain (fit), 1 = cover (fill)
    in-out property <int> video-fit-mode: 0;
    in-out property <bool> stay-on-top: false;

    always-on-top: root.stay-on-top;

    in property <image> current-frame;
    /// Diagonal-stripe loading pattern shown on audio/video chips whose
    /// background asset (waveform / thumbnail strip) hasn't finished
    /// generating yet. Raster'd once at startup by `asset_cache::install`
    /// and never mutated thereafter. Left empty if the host fails to init
    /// the cache — chips just show flat color in that case.
    in property <image> timeline-placeholder-stripe;
    in property <float> duration-ms: 0;
    /// Timeline position; **in-out** so the timeline `Slider` can two-way bind while Rust/player updates during playback.
    in-out property <float> playhead-ms: 0;
    in property <bool> is-playing: false;
    in property <bool> media-ready: false;
    /// Transient messages (export, errors, undo feedback). The bottom strip is shown only when **View → Show Status** is on; then codec/path/save lines appear when a project is loaded.
    in property <string> status-text: "";

    in property <bool> close-enabled: false;
    in property <bool> revert-enabled: false;
    in property <bool> save-enabled: false;
    in property <bool> undo-enabled: false;
    in property <bool> redo-enabled: false;
    in property <bool> move-clip-down-enabled: false;
    in property <bool> move-clip-up-enabled: false;
    in property <bool> split-at-playhead-enabled: false;
    /// True when a primary-track clip applies at the playhead (rotate/flip); not gated on decode.
    in property <bool> rotate-enabled: false;
    /// Same gate as `rotate-enabled` — the **Trim Clip…** sheet needs a clip under the playhead.
    in property <bool> trim-enabled: false;
    /// Same gate as `rotate-enabled` — the **Resize Video…** sheet needs a clip under the playhead.
    in property <bool> resize-enabled: false;
    /// True when the clip under the playhead is eligible for the **Mute Clip Audio** toggle.
    in property <bool> audio-mute-enabled: false;
    /// Checked state for the **Edit → Mute Clip Audio** toggle (clip under playhead).
    in property <bool> audio-mute-active: false;
    /// True when **Edit → Overlay Audio…** is clickable. Gate = `media-ready`
    /// (a project must exist so the new lane has somewhere to live).
    in property <bool> overlay-audio-enabled: false;
    /// True when **Edit → Replace Audio…** is clickable. Same gate as
    /// `overlay-audio-enabled` — the replace helper mutes every primary clip
    /// and appends a fresh audio lane in a single undoable step, so it only
    /// needs a project to work against.
    in property <bool> replace-audio-enabled: false;
    /// True when **Edit → Replace & Clear Other Audio…** is clickable. Same
    /// gate as `replace-audio-enabled`; this variant additionally drops every
    /// existing `TrackKind::Audio` lane so the project ends up with exactly
    /// one audio source (the new clip), all under one undo snapshot.
    in property <bool> replace-audio-clear-others-enabled: false;
    /// True when **Edit → Audio Lane Gain…** is clickable — requires `media-ready`
    /// AND at least one `TrackKind::Audio` lane (otherwise the sheet has nothing
    /// to act on). Gate flipped in `sync_menu` via `session::audio_track_count`.
    in property <bool> audio-gain-enabled: false;
    /// Edit → Audio Track submenu. The primary-track clip at the playhead may
    /// expose several audio streams (language, commentary, 5.1+stereo). Up to
    /// six slots are shown; `audio-track-label-N` is empty when that slot is
    /// unused and the corresponding `MenuItem` disables + hides its text.
    /// `audio-track-checked-N` is the radio state for stream N.
    /// `audio-track-default-checked` flips true when the clip has no explicit
    /// pick (`Clip.audio_stream_index = None` — the pre-multi-audio default).
    /// `audio-track-enabled` gates the whole submenu on media-ready + ≥ 2
    /// audio streams on the current clip (single-stream files have nothing
    /// to pick between).
    in property <bool> audio-track-enabled: false;
    in property <bool> audio-track-default-checked: true;
    in property <string> audio-track-label-0: "";
    in property <string> audio-track-label-1: "";
    in property <string> audio-track-label-2: "";
    in property <string> audio-track-label-3: "";
    in property <string> audio-track-label-4: "";
    in property <string> audio-track-label-5: "";
    in property <bool> audio-track-checked-0: false;
    in property <bool> audio-track-checked-1: false;
    in property <bool> audio-track-checked-2: false;
    in property <bool> audio-track-checked-3: false;
    in property <bool> audio-track-checked-4: false;
    in property <bool> audio-track-checked-5: false;
    /// Container stream index corresponding to each slot (`AudioStreamInfo.index`).
    /// Needed because slot positions are dense (0..N) but container indices may
    /// be sparse (e.g. 1, 2, 5 on files with interleaved subtitle streams).
    in property <int> audio-track-index-0: -1;
    in property <int> audio-track-index-1: -1;
    in property <int> audio-track-index-2: -1;
    in property <int> audio-track-index-3: -1;
    in property <int> audio-track-index-4: -1;
    in property <int> audio-track-index-5: -1;
    /// Fires when the user picks an entry. `stream-index < 0` → reset to the
    /// "Default (auto)" state (`Clip.audio_stream_index = None`).
    callback edit-set-audio-track(int);

    // --- Audio lane gain sheet (Edit → Audio Lane Gain…) ---
    /// Visibility flag; flipped by Rust when the menu item fires and off again
    /// when the user confirms or cancels.
    in-out property <bool> gain-sheet-visible: false;
    /// 1-based lane number shown/edited in the sheet. Rust prefills with `1`
    /// when opening; validation happens on confirm against `gain-sheet-max-lane`.
    in-out property <int> gain-sheet-lane: 1;
    /// Current gain in dB for the prefilled lane (display + initial value for
    /// the input field). Updated by Rust when the sheet opens or when the
    /// user re-enters a valid lane number (handled in Rust).
    in-out property <float> gain-sheet-db: 0.0;
    /// Audio-lane count at the moment the sheet opens. Used by the sheet for
    /// inline range hints; `0` hides the sheet content (the menu gate should
    /// prevent this from ever being 0 at open time, but we belt-and-brace).
    in property <int> gain-sheet-max-lane: 0;
    /// Inline error text shown under the fields; empty hides the row.
    in property <string> gain-sheet-error: "";

    // --- Resize sheet (Edit → Resize Video…) ---
    in-out property <bool> resize-sheet-visible: false;
    /// Current scale percent for the clip under the playhead (100 = identity).
    in-out property <int> resize-percent: 100;
    /// Source video dimensions for display in the sheet (0 when unknown).
    in property <int> resize-source-width: 0;
    in property <int> resize-source-height: 0;
    /// Error label under the field; empty hides it.
    in property <string> resize-error: "";

    // --- Trim sheet (Edit → Trim Clip…) ---
    in-out property <bool> trim-sheet-visible: false;
    /// Prefilled by Rust when the sheet opens. The sheet writes the confirmed values back
    /// via `trim-confirm(begin, end)`; these bindings are for display only.
    in-out property <float> trim-begin-s: 0.0;
    in-out property <float> trim-end-s: 0.0;
    /// Source-file duration for the clip being trimmed; `0` when probe didn't report one.
    in property <float> trim-source-duration-s: 0.0;
    /// Error label under the fields; empty hides it.
    in property <string> trim-error: "";

    // --- Seek-bar In/Out markers (ephemeral session state) ---
    /// `-1` when unset; otherwise the sequence-ms position of the In marker.
    /// (`Option<f64>` doesn't have a Slint representation, so we use sentinel `-1`.)
    in property <float> marker-in-ms: -1;
    in property <float> marker-out-ms: -1;
    /// True when at least one marker is set — gates **Edit → Clear Range Markers**.
    in property <bool> marker-any-set: false;
    in property <bool> export-in-progress: false;
    /// 0.0–1.0 while exporting; reset when export ends.
    in property <float> export-progress: 0.0;
    in property <bool> insert-audio-enabled: false;
    /// Enabled when **media-ready** AND at least one `TrackKind::Subtitle` lane exists
    /// (gate set in `sync_menu`).
    in property <bool> insert-subtitle-enabled: false;

    /// One line per video track lane, newline-separated (see session.video_track_row_labels).
    in property <string> video-track-lanes: "";
    /// One line per audio track lane, newline-separated (see session.audio_track_row_labels).
    in property <string> audio-track-lanes: "";
    /// Filmstrip chips per lane (up to four lanes each; widths from clip durations).
    in property <[TlChip]> tl_vrow0: [];
    in property <[TlChip]> tl_vrow1: [];
    in property <[TlChip]> tl_vrow2: [];
    in property <[TlChip]> tl_vrow3: [];
    in property <[TlChip]> tl_arow0: [];
    in property <[TlChip]> tl_arow1: [];
    in property <[TlChip]> tl_arow2: [];
    in property <[TlChip]> tl_arow3: [];
    in property <int> tl_video_track_count: 0;
    in property <int> tl_audio_track_count: 0;
    /// Subtitle lanes from container probe (single-media mode only).
    in property <int> tl_subtitle_track_count: 0;
    /// Project-backed video/audio/subtitle track counts (for delete affordances). Display counts may be higher when showing container streams.
    in property <int> tl_video_project_track_count: 0;
    in property <int> tl_audio_project_track_count: 0;
    in property <int> tl_subtitle_project_track_count: 0;
    in property <[TlChip]> tl_srow0: [];
    in property <[TlChip]> tl_srow1: [];
    in property <[TlChip]> tl_srow2: [];
    in property <[TlChip]> tl_srow3: [];
    /// Elapsed sequence time (left of timeline scrubber); `M:SS.t` / `H:MM:SS.t`.
    in property <string> time-elapsed: "0:00.0";
    /// Total sequence duration (right of scrubber); same format as `time-elapsed`.
    in property <string> time-total: "0:00.0";

    in property <string> recent-line0: "";
    in property <string> recent-line1: "";
    in property <string> recent-line2: "";
    in property <string> recent-line3: "";
    in property <string> recent-line4: "";
    in property <string> recent-line5: "";
    in property <string> recent-line6: "";
    in property <string> recent-line7: "";
    in property <string> recent-line8: "";
    in property <string> recent-line9: "";
    in property <bool> recent-has-entries: false;

    /// Footer strip when `media-ready` (codecs, paths, save state).
    in property <string> footer-codec-line: "";
    in property <string> footer-path-line: "";
    in property <string> footer-save-line: "";
    in property <bool> footer-unsaved: false;
    /// True when a project / media is loaded — codec/path/save lines are filled when **View → Show Status** is on (see `sync_footer`).
    in property <bool> footer-visible: false;
    callback footer-refresh();

    callback file-open();
    callback file-open-recent(int);
    callback file-clear-recent();
    callback file-close();
    callback file-revert();
    callback file-new-window();
    callback file-save();
    callback file-insert-video();
    callback file-insert-audio();
    callback file-insert-subtitle();
    callback file-new-video-track();
    callback file-new-audio-track();
    callback file-new-subtitle-track();
    /// Remove timeline lane by index (`0` = V1 / A1). Video: requires a spare lane; audio: any lane.
    callback delete-video-track(int);
    callback delete-audio-track(int);
    callback delete-subtitle-track(int);
    /// U2-c: per-clip edge-drag trim commit. `clip-id` is the UUID of the
    /// backing `reel_core::project::Clip`, `edge` is 0 (left = in-point) or 1
    /// (right = out-point), `delta-ratio` is drag distance as a fraction of the
    /// chip's rendered width. Rust applies `new = old + delta-ratio * (end-begin)`
    /// and delegates to `session::trim_clip`, whose invariants reject
    /// over-extension / sub-50-ms clips without pushing undo.
    /// Ripple is automatic — the project's sequential clip model has no absolute
    /// timeline positions, so shrinking any clip pulls the rest forward.
    callback clip-trim-commit(string /* clip-id */, int /* edge */, float /* delta-ratio */);
    /// Fired from the Rust-side AssetCache worker (via
    /// `slint::invoke_from_event_loop`) whenever a waveform / thumbnail
    /// raster completes. The handler re-runs `sync_timeline_chips` so the
    /// chip models pick up the freshly-cached image and the placeholder
    /// stripe gives way to the real graphic. No arguments — the session
    /// and window already know everything needed to rebuild.
    callback refresh-timeline-chips();
    callback file-export();
    callback export-cancel();
    callback export-preset-cancel();
    callback export-preset-confirm();

    in-out property <bool> export-preset-dialog-visible: false;
    /// 0 = MP4 remux, 1 = MP4 H.264+AAC, 2 = MP4 H.265+AAC,
    /// 3 = WebM VP8+Opus, 4 = WebM VP9+Opus, 5 = WebM AV1+Opus,
    /// 6 = MKV remux, 7 = MOV remux (`docs/SUPPORTED_FORMATS.md`).
    in-out property <int> export-preset-index: 0;

    callback edit-undo();
    callback edit-redo();
    callback edit-split-at-playhead();
    callback edit-move-clip-down();
    callback edit-move-clip-up();
    callback edit-rotate-right();
    callback edit-rotate-left();
    callback edit-flip-horizontal();
    callback edit-flip-vertical();
    /// Opens the Trim Clip… sheet for the clip under the playhead.
    callback edit-trim-clip();
    /// User pressed Trim in the sheet. Args are the entered begin / end seconds.
    callback trim-confirm(float, float);
    callback trim-cancel();

    /// Opens the Resize Video… sheet for the clip under the playhead.
    callback edit-resize-clip();
    /// User pressed Resize in the sheet. Arg is the entered scale percent.
    callback resize-confirm(int);
    callback resize-cancel();

    /// **Edit → Mute Clip Audio**: toggle `audio_mute` on the clip under the playhead.
    callback edit-toggle-audio-mute();

    /// **Edit → Overlay Audio…**: open an audio-file picker and append the
    /// pick on a **new** dedicated audio lane. Export `amix` mixes the overlay
    /// alongside the existing audio lanes (U2-b-export); preview remains
    /// first-lane-only until the audio-thread rewrite.
    callback edit-overlay-audio();

    /// **Edit → Replace Audio…**: open an audio-file picker, mute every clip
    /// on the primary video track, and append the pick on a new dedicated
    /// audio lane — all in a single undo step. Export mixes via the same
    /// `amix` path as overlay. Preview now sums every audio lane with
    /// per-lane gain, so the replacement clip is audible alongside any
    /// existing overlays immediately after confirm.
    callback edit-replace-audio();

    /// **Edit → Replace & Clear Other Audio…**: like `edit-replace-audio` but
    /// additionally removes every existing `TrackKind::Audio` lane before
    /// appending the new one, so the project ends up with exactly one audio
    /// source. All three steps (mute primary, drop existing lanes, append the
    /// new lane) live under one undo snapshot.
    callback edit-replace-audio-clear-others();

    /// **Edit → Audio Lane Gain…**: open a sheet for adjusting the per-lane
    /// `gain_db` on a `TrackKind::Audio` track (1-based lane number; ±40 dB
    /// range, clamped in the session helper). Applied at export via amix
    /// `volume=XdB`; preview remains first-lane-only and does not yet honor
    /// the gain.
    callback edit-audio-lane-gain();
    /// User pressed **Set Gain** in the sheet. Args are the 1-based lane number
    /// and the dB value from the fields; Rust clamps & validates and sets the
    /// `gain-sheet-error` string on failure (leaving the sheet open).
    callback gain-confirm(int, float);
    /// Dismiss the sheet without mutating the project.
    callback gain-cancel();
    /// User edited the lane number in the sheet; Rust refreshes `gain-sheet-db`
    /// with the current value on that lane so the dB field tracks which lane
    /// is about to be edited. Arg is the 1-based lane number.
    callback gain-lane-changed(int);

    /// **Edit → Set In Point** (`I`): marks the current playhead as the range start.
    callback edit-set-in-marker();
    /// **Edit → Set Out Point** (`O`): marks the current playhead as the range end.
    callback edit-set-out-marker();
    /// **Edit → Clear Range Markers** (`Option+X` / `Alt+X`): removes both markers.
    callback edit-clear-markers();
    /// Drag of the yellow **In** handle on the scrub bar — argument is the new
    /// absolute sequence position in milliseconds (clamped in Slint so the In
    /// handle can't cross the Out handle).
    callback edit-drag-in-marker-ms(float);
    /// Drag of the yellow **Out** handle on the scrub bar — argument is the new
    /// absolute sequence position in milliseconds (clamped in Slint so the Out
    /// handle can't cross the In handle).
    callback edit-drag-out-marker-ms(float);

    callback effect-face-swap();
    callback effect-face-enhance();
    callback effect-remove-background();

    callback win-fit();
    callback win-fill();
    callback win-center();
    callback win-toggle-on-top();

    /// When true, playback restarts from the start at sequence end (saved in prefs).
    in-out property <bool> loop-playback: false;
    callback view-toggle-loop();
    /// Codec / path / save footer line (saved in prefs).
    in-out property <bool> view-show-status: false;
    callback view-toggle-show-status();
    /// Pixel offsets applied on top of the default center/bottom placement of
    /// the floating transport chrome. Driven by the grip-handle drag (see
    /// `grip-ta` in the chrome row). Persisted as plain `length` so we don’t
    /// need a separate user pref surface — they reset when the window closes.
    in-out property <length> chrome-offset-x: 0;
    in-out property <length> chrome-offset-y: 0;
    /// Keep the floating transport from auto-hiding (saved in prefs).
    in-out property <bool> controls-overlay-always-visible: false;
    callback view-toggle-controls-always-visible();
    /// Timeline lane rows (v0 **View** — Video / Audio / Subtitle tracks); saved in prefs.
    in-out property <bool> view-show-video-tracks: true;
    in-out property <bool> view-show-audio-tracks: true;
    in-out property <bool> view-show-subtitle-tracks: true;
    callback view-toggle-video-tracks();
    callback view-toggle-audio-tracks();
    callback view-toggle-subtitle-tracks();

    /// Manual A/V offset in **signed** milliseconds (Preferences → A/V
    /// Offset). Positive values say audio arrives later than the auto-
    /// calibrated device latency and hold the picture back. Driven by
    /// submenu nudges (±25 ms) and **Shift+Arrow** keyboard shortcuts,
    /// plus a Reset; persisted in prefs. The Rust-side clamp is ±30 000 ms
    /// (`AUDIO_OFFSET_RANGE_MS`) — wide enough for bring-your-own-audio
    /// overlay pre-roll plus any device-latency outlier.
    in-out property <int> audio-offset-ms: 0;
    /// Nudge the offset by `delta_ms`. Rust clamps and persists; the
    /// property is updated on return. `0` = reset to zero.
    callback audio-offset-nudge(int);
    callback audio-offset-reset();

    /// Last decoded frame size (pixels); used for zoom and **Actual Size**.
    in property <float> preview-frame-width: 640.0;
    in property <float> preview-frame-height: 360.0;
    /// **25–400** — percent of **fit** (contain/cover) size; ignored when `preview-zoom-actual`.
    in-out property <float> preview-zoom-percent: 100.0;
    /// **True** = 1:1 logical pixels for the preview frame.
    in-out property <bool> preview-zoom-actual: false;
    /// Mirrors OS fullscreen when toggled from the app (Esc exits).
    in-out property <bool> window-fullscreen: false;

    callback view-zoom-in();
    callback view-zoom-out();
    callback view-zoom-fit();
    callback view-zoom-actual-size();
    callback view-toggle-fullscreen();
    callback view-exit-fullscreen();

    callback help-about();
    callback help-overview();
    callback help-features();
    callback help-keyboard();
    callback help-media-formats();
    callback help-supported-formats();
    callback help-cli();
    callback help-external-ai();
    callback help-developers();
    callback help-agents();
    callback help-phases-ui();

    callback play-pause();

    callback seek-timeline(float);
    /// Nudge playhead by delta milliseconds (e.g. ±1000 for arrow keys).
    callback seek-nudge-ms(float);

    /// Master preview volume **0..100** (persisted).
    in-out property <float> volume-percent: 100.0;
    callback volume-changed(float);

    /// Preview rate label (e.g. `1.00×`, `-0.50×`) — mirrors signed speed in the player.
    in-out property <string> transport-rate-label: "1.00×";
    /// Floating transport over the video; fades out after idle (see `transport-chrome-hide`).
    property <float> transport-chrome-opacity: 1.0;
    callback transport-forward();
    callback transport-rewind();

    /// Tools menu above the double-chevron control (v0 mock — Magic Wand…Effects submenu).
    /// Default **closed** (v0); Rust also resets on media load/close so state does not carry over.
    in-out property <bool> tools-popup-open: false;
    in-out property <bool> tools-effects-submenu-open: false;

    transport-chrome-hide := Timer {
        interval: 5s;
        triggered => {
            if (!root.controls-overlay-always-visible) {
                root.transport-chrome-opacity = 0.0;
                root.tools-popup-open = false;
                root.tools-effects-submenu-open = false;
            }
        }
    }

    function wake-transport-chrome() {
        root.transport-chrome-opacity = 1.0;
        if (!root.controls-overlay-always-visible) {
            transport-chrome-hide.restart();
        }
    }

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Open…";
                icon: @image-url("icons/lucide/folder-open.svg");
                shortcut: @keys(Control + O);
                activated => { root.file-open(); }
            }
            Menu {
                title: "Open Recent";
                icon: @image-url("icons/lucide/clock.svg");
                MenuItem {
                    title: root.recent-line0;
                    enabled: root.recent-line0 != "";
                    activated => { root.file-open-recent(0); }
                }
                MenuItem {
                    title: root.recent-line1;
                    enabled: root.recent-line1 != "";
                    activated => { root.file-open-recent(1); }
                }
                MenuItem {
                    title: root.recent-line2;
                    enabled: root.recent-line2 != "";
                    activated => { root.file-open-recent(2); }
                }
                MenuItem {
                    title: root.recent-line3;
                    enabled: root.recent-line3 != "";
                    activated => { root.file-open-recent(3); }
                }
                MenuItem {
                    title: root.recent-line4;
                    enabled: root.recent-line4 != "";
                    activated => { root.file-open-recent(4); }
                }
                MenuItem {
                    title: root.recent-line5;
                    enabled: root.recent-line5 != "";
                    activated => { root.file-open-recent(5); }
                }
                MenuItem {
                    title: root.recent-line6;
                    enabled: root.recent-line6 != "";
                    activated => { root.file-open-recent(6); }
                }
                MenuItem {
                    title: root.recent-line7;
                    enabled: root.recent-line7 != "";
                    activated => { root.file-open-recent(7); }
                }
                MenuItem {
                    title: root.recent-line8;
                    enabled: root.recent-line8 != "";
                    activated => { root.file-open-recent(8); }
                }
                MenuItem {
                    title: root.recent-line9;
                    enabled: root.recent-line9 != "";
                    activated => { root.file-open-recent(9); }
                }
                MenuSeparator { }
                MenuItem {
                    title: "Clear Recent";
                    icon: @image-url("icons/lucide/trash-2.svg");
                    enabled: root.recent-has-entries;
                    activated => { root.file-clear-recent(); }
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Close";
                icon: @image-url("icons/lucide/x.svg");
                shortcut: @keys(Control + W);
                enabled: root.close-enabled && !root.export-in-progress;
                activated => { root.file-close(); }
            }
            MenuItem {
                title: "Revert";
                icon: @image-url("icons/lucide/undo-2.svg");
                enabled: root.revert-enabled;
                activated => { root.file-revert(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "New Window";
                icon: @image-url("icons/lucide/app-window.svg");
                activated => { root.file-new-window(); }
            }
            MenuItem {
                title: "Save…";
                icon: @image-url("icons/lucide/save.svg");
                shortcut: @keys(Control + S);
                enabled: root.save-enabled;
                activated => { root.file-save(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Insert Video…";
                icon: @image-url("icons/lucide/file-video.svg");
                shortcut: @keys(Control + I);
                activated => { root.file-insert-video(); }
            }
            MenuItem {
                title: "Insert Audio…";
                icon: @image-url("icons/lucide/file-audio.svg");
                shortcut: @keys(Control + Shift + I);
                enabled: root.insert-audio-enabled;
                activated => { root.file-insert-audio(); }
            }
            MenuItem {
                title: "Insert Subtitle…";
                icon: @image-url("icons/lucide/type.svg");
                shortcut: @keys(Control + Alt + I);
                enabled: root.insert-subtitle-enabled;
                activated => { root.file-insert-subtitle(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "New Video Track";
                icon: @image-url("icons/lucide/film.svg");
                shortcut: @keys(Control + Shift + N);
                enabled: root.media-ready;
                activated => { root.file-new-video-track(); }
            }
            MenuItem {
                title: "New Audio Track";
                icon: @image-url("icons/lucide/music.svg");
                shortcut: @keys(Control + Shift + A);
                enabled: root.media-ready;
                activated => { root.file-new-audio-track(); }
            }
            MenuItem {
                title: "New Subtitle Track";
                icon: @image-url("icons/lucide/type.svg");
                shortcut: @keys(Control + Shift + T);
                enabled: root.media-ready;
                activated => { root.file-new-subtitle-track(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Export…";
                icon: @image-url("icons/lucide/download.svg");
                shortcut: @keys(Control + E);
                enabled: root.media-ready && !root.export-in-progress && !root.export-preset-dialog-visible;
                activated => { root.file-export(); }
            }
            MenuItem {
                title: "Cancel Export";
                icon: @image-url("icons/lucide/x.svg");
                shortcut: @keys(Escape);
                enabled: root.export-in-progress;
                activated => { root.export-cancel(); }
            }
        }
        Menu {
            title: "Edit";
            MenuItem {
                title: "Undo";
                icon: @image-url("icons/lucide/undo-2.svg");
                shortcut: @keys(Control + Z);
                enabled: root.undo-enabled;
                activated => { root.edit-undo(); }
            }
            MenuItem {
                title: "Redo";
                icon: @image-url("icons/lucide/redo-2.svg");
                shortcut: @keys(Control + Shift + Z);
                enabled: root.redo-enabled;
                activated => { root.edit-redo(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Split Clip at Playhead";
                icon: @image-url("icons/lucide/scissors.svg");
                shortcut: @keys(Control + B);
                enabled: root.split-at-playhead-enabled;
                activated => { root.edit-split-at-playhead(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Move Clip to Track Below";
                icon: @image-url("icons/lucide/arrow-down.svg");
                shortcut: @keys(Control + Shift + DownArrow);
                enabled: root.move-clip-down-enabled;
                activated => { root.edit-move-clip-down(); }
            }
            MenuItem {
                title: "Move Clip to Track Above";
                icon: @image-url("icons/lucide/arrow-up.svg");
                shortcut: @keys(Control + Shift + UpArrow);
                enabled: root.move-clip-up-enabled;
                activated => { root.edit-move-clip-up(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Rotate 90° Right";
                icon: @image-url("icons/lucide/rotate-cw.svg");
                shortcut: @keys(Control + R);
                enabled: root.rotate-enabled;
                activated => { root.edit-rotate-right(); }
            }
            MenuItem {
                title: "Rotate 90° Left";
                icon: @image-url("icons/lucide/rotate-ccw.svg");
                shortcut: @keys(Control + Shift + R);
                enabled: root.rotate-enabled;
                activated => { root.edit-rotate-left(); }
            }
            MenuItem {
                title: "Flip Horizontal";
                icon: @image-url("icons/lucide/flip-horizontal-2.svg");
                enabled: root.rotate-enabled;
                activated => { root.edit-flip-horizontal(); }
            }
            MenuItem {
                title: "Flip Vertical";
                icon: @image-url("icons/lucide/flip-vertical-2.svg");
                enabled: root.rotate-enabled;
                activated => { root.edit-flip-vertical(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Trim Clip…";
                icon: @image-url("icons/lucide/crop.svg");
                enabled: root.trim-enabled;
                activated => { root.edit-trim-clip(); }
            }
            MenuItem {
                title: "Resize Video…";
                icon: @image-url("icons/lucide/maximize.svg");
                enabled: root.resize-enabled;
                activated => { root.edit-resize-clip(); }
            }
            MenuItem {
                title: "Mute Clip Audio";
                icon: @image-url("icons/lucide/volume-x.svg");
                checkable: true;
                checked: root.audio-mute-active;
                enabled: root.audio-mute-enabled;
                activated => { root.edit-toggle-audio-mute(); }
            }
            MenuItem {
                title: "Overlay Audio…";
                icon: @image-url("icons/lucide/layers.svg");
                enabled: root.overlay-audio-enabled;
                activated => { root.edit-overlay-audio(); }
            }
            MenuItem {
                title: "Replace Audio…";
                icon: @image-url("icons/lucide/replace.svg");
                enabled: root.replace-audio-enabled;
                activated => { root.edit-replace-audio(); }
            }
            MenuItem {
                title: "Replace & Clear Other Audio…";
                icon: @image-url("icons/lucide/replace.svg");
                enabled: root.replace-audio-clear-others-enabled;
                activated => { root.edit-replace-audio-clear-others(); }
            }
            MenuItem {
                title: "Audio Lane Gain…";
                icon: @image-url("icons/lucide/volume-2.svg");
                enabled: root.audio-gain-enabled;
                activated => { root.edit-audio-lane-gain(); }
            }
            Menu {
                title: "Audio Track";
                icon: @image-url("icons/lucide/music.svg");
                MenuItem {
                    title: "Default (auto)";
                    checkable: true;
                    checked: root.audio-track-default-checked;
                    enabled: root.audio-track-enabled;
                    activated => { root.edit-set-audio-track(-1); }
                }
                MenuItem {
                    title: root.audio-track-label-0;
                    checkable: true;
                    checked: root.audio-track-checked-0;
                    enabled: root.audio-track-enabled && root.audio-track-label-0 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-0); }
                }
                MenuItem {
                    title: root.audio-track-label-1;
                    checkable: true;
                    checked: root.audio-track-checked-1;
                    enabled: root.audio-track-enabled && root.audio-track-label-1 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-1); }
                }
                MenuItem {
                    title: root.audio-track-label-2;
                    checkable: true;
                    checked: root.audio-track-checked-2;
                    enabled: root.audio-track-enabled && root.audio-track-label-2 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-2); }
                }
                MenuItem {
                    title: root.audio-track-label-3;
                    checkable: true;
                    checked: root.audio-track-checked-3;
                    enabled: root.audio-track-enabled && root.audio-track-label-3 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-3); }
                }
                MenuItem {
                    title: root.audio-track-label-4;
                    checkable: true;
                    checked: root.audio-track-checked-4;
                    enabled: root.audio-track-enabled && root.audio-track-label-4 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-4); }
                }
                MenuItem {
                    title: root.audio-track-label-5;
                    checkable: true;
                    checked: root.audio-track-checked-5;
                    enabled: root.audio-track-enabled && root.audio-track-label-5 != "";
                    activated => { root.edit-set-audio-track(root.audio-track-index-5); }
                }
            }
            MenuSeparator { }
            MenuItem {
                title: "Set In Point";
                enabled: root.media-ready;
                activated => { root.edit-set-in-marker(); }
            }
            MenuItem {
                title: "Set Out Point";
                enabled: root.media-ready;
                activated => { root.edit-set-out-marker(); }
            }
            MenuItem {
                title: "Clear Range Markers";
                enabled: root.marker-any-set;
                activated => { root.edit-clear-markers(); }
            }
        }
        Menu {
            title: "Effects";
            MenuItem {
                title: "Face Swap (FaceFusion)…";
                icon: @image-url("icons/lucide/user.svg");
                enabled: root.media-ready;
                activated => { root.effect-face-swap(); }
            }
            MenuItem {
                title: "Face Enhance…";
                icon: @image-url("icons/lucide/wand-2.svg");
                enabled: root.media-ready;
                activated => { root.effect-face-enhance(); }
            }
            MenuItem {
                title: "Remove Background (RVM-style)…";
                icon: @image-url("icons/lucide/eraser.svg");
                enabled: root.media-ready;
                activated => { root.effect-remove-background(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "AI Upscale…";
                icon: @image-url("icons/lucide/sparkles.svg");
                enabled: false;
            }
        }
        Menu {
            title: "View";
            MenuItem {
                title: "Loop Playback";
                checkable: true;
                checked: root.loop-playback;
                icon: @image-url("icons/lucide/repeat.svg");
                shortcut: @keys(Control + L);
                activated => { root.view-toggle-loop(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Zoom In";
                icon: @image-url("icons/lucide/zoom-in.svg");
                shortcut: @keys(Control + "+");
                enabled: root.media-ready && (root.preview-zoom-actual || root.preview-zoom-percent < 400.0);
                activated => { root.view-zoom-in(); }
            }
            MenuItem {
                title: "Zoom Out";
                icon: @image-url("icons/lucide/zoom-out.svg");
                shortcut: @keys(Control + "-");
                enabled: root.media-ready && (root.preview-zoom-actual || root.preview-zoom-percent > 25.0);
                activated => { root.view-zoom-out(); }
            }
            MenuItem {
                title: "Zoom to Fit";
                shortcut: @keys(Control + Digit0);
                enabled: root.media-ready;
                activated => { root.view-zoom-fit(); }
            }
            MenuItem {
                title: "Actual Size";
                enabled: root.media-ready;
                activated => { root.view-zoom-actual-size(); }
            }
            MenuSeparator { }
            MenuItem {
                title: root.window-fullscreen ? "Exit Fullscreen" : "Enter Fullscreen";
                icon: root.window-fullscreen ? @image-url("icons/lucide/minimize.svg") : @image-url("icons/lucide/maximize.svg");
                shortcut: @keys(Escape);
                activated => { root.view-toggle-fullscreen(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Video Tracks";
                checkable: true;
                checked: root.view-show-video-tracks;
                icon: root.view-show-video-tracks ? @image-url("icons/lucide/eye.svg") : @image-url("icons/lucide/eye-off.svg");
                activated => { root.view-toggle-video-tracks(); }
            }
            MenuItem {
                title: "Audio Tracks";
                checkable: true;
                checked: root.view-show-audio-tracks;
                icon: root.view-show-audio-tracks ? @image-url("icons/lucide/eye.svg") : @image-url("icons/lucide/eye-off.svg");
                activated => { root.view-toggle-audio-tracks(); }
            }
            MenuItem {
                title: "Subtitle Tracks";
                checkable: true;
                checked: root.view-show-subtitle-tracks;
                icon: root.view-show-subtitle-tracks ? @image-url("icons/lucide/eye.svg") : @image-url("icons/lucide/eye-off.svg");
                activated => { root.view-toggle-subtitle-tracks(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Show Status";
                checkable: true;
                checked: root.view-show-status;
                icon: root.view-show-status ? @image-url("icons/lucide/eye.svg") : @image-url("icons/lucide/eye-off.svg");
                activated => { root.view-toggle-show-status(); }
            }
            MenuItem {
                title: "Always Show Controls";
                checkable: true;
                checked: root.controls-overlay-always-visible;
                icon: @image-url("icons/lucide/layers.svg");
                activated => { root.view-toggle-controls-always-visible(); }
            }
            MenuSeparator { }
            // A/V Offset submenu — manual device-latency nudge on top of
            // the cpal auto-calibration. Stored in prefs and applied to
            // the audio clock at startup / on every change.
            Menu {
                title: "A/V Offset";
                icon: @image-url("icons/lucide/clock.svg");
                MenuItem {
                    title: "Current: " + root.audio-offset-ms + " ms";
                    enabled: false;
                }
                MenuSeparator { }
                MenuItem {
                    title: "Shift Earlier (−25 ms)  ⇧←";
                    icon: @image-url("icons/lucide/arrow-left.svg");
                    activated => { root.audio-offset-nudge(-25); }
                }
                MenuItem {
                    title: "Shift Later (+25 ms)  ⇧→";
                    icon: @image-url("icons/lucide/arrow-right.svg");
                    activated => { root.audio-offset-nudge(25); }
                }
                MenuSeparator { }
                MenuItem {
                    title: "Reset to 0 ms";
                    enabled: root.audio-offset-ms != 0;
                    activated => { root.audio-offset-reset(); }
                }
            }
        }
        Menu {
            title: "Window";
            MenuItem {
                title: "Always on Top";
                checkable: true;
                checked: root.stay-on-top;
                icon: @image-url("icons/lucide/panel-top.svg");
                activated => { root.win-toggle-on-top(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Fit";
                activated => { root.win-fit(); }
            }
            MenuItem {
                title: "Fill";
                activated => { root.win-fill(); }
            }
            MenuItem {
                title: "Center";
                activated => { root.win-center(); }
            }
        }
        Menu {
            title: "Help";
            MenuItem {
                title: "About Reel…";
                activated => { root.help-about(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Overview";
                icon: @image-url("icons/lucide/help-circle.svg");
                shortcut: @keys(F1);
                activated => { root.help-overview(); }
            }
            MenuItem {
                title: "Features & roadmap";
                activated => { root.help-features(); }
            }
            MenuItem {
                title: "Keyboard shortcuts";
                activated => { root.help-keyboard(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Media formats & tracks";
                activated => { root.help-media-formats(); }
            }
            MenuItem {
                title: "Supported formats (playback vs export)";
                activated => { root.help-supported-formats(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "CLI (reel-cli)";
                activated => { root.help-cli(); }
            }
            MenuItem {
                title: "External AI & tools";
                activated => { root.help-external-ai(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Developers";
                activated => { root.help-developers(); }
            }
            MenuItem {
                title: "Agent guide (Cursor / Claude)";
                activated => { root.help-agents(); }
            }
            MenuItem {
                title: "UI phases roadmap";
                activated => { root.help-phases-ui(); }
            }
        }
    }

    main-view-focus := FocusScope {
        vertical-stretch: 1;
        width: 100%;
        focus-on-click: true;
        key-pressed(event) => {
            // File: Open / Save work without media (e.g. empty window — Open a project).
            if (event.text == Key.O && event.modifiers.control && !event.modifiers.shift) {
                root.file-open();
                accept
            } else if (event.text == Key.S && event.modifiers.control && !event.modifiers.shift) {
                if (root.save-enabled) {
                    root.file-save();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.W && event.modifiers.control && !event.modifiers.shift) {
                if (root.close-enabled && !root.export-in-progress) {
                    root.file-close();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.F1) {
                root.help-overview();
                accept
            } else if (event.text == Key.Escape) {
                if (root.window-fullscreen) {
                    root.view-exit-fullscreen();
                    accept
                } else if (root.trim-sheet-visible) {
                    root.trim-cancel();
                    accept
                } else if (root.gain-sheet-visible) {
                    root.gain-cancel();
                    accept
                } else if (root.export-preset-dialog-visible) {
                    root.export-preset-cancel();
                    accept
                } else if (root.export-in-progress) {
                    root.export-cancel();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.L && event.modifiers.control && !event.modifiers.shift) {
                root.view-toggle-loop();
                accept
            } else if (event.text == "=" && event.modifiers.control && !event.modifiers.shift) {
                root.view-zoom-in();
                accept
            } else if (event.text == "-" && event.modifiers.control && !event.modifiers.shift) {
                root.view-zoom-out();
                accept
            } else if (event.text == "0" && event.modifiers.control && !event.modifiers.shift) {
                root.view-zoom-fit();
                accept
            // Shift+Left / Shift+Right: nudge A/V sync offset earlier / later by 25 ms.
            // Not gated on media-ready since A/V offset is a device-latency pref and
            // the menu lets the user dial it in with or without a project loaded.
            } else if (event.text == Key.LeftArrow && event.modifiers.shift && !event.modifiers.control && !event.modifiers.alt) {
                root.audio-offset-nudge(-25);
                accept
            } else if (event.text == Key.RightArrow && event.modifiers.shift && !event.modifiers.control && !event.modifiers.alt) {
                root.audio-offset-nudge(25);
                accept
            } else if (!root.media-ready) {
                reject
            } else if (event.text == Key.N && event.modifiers.control && event.modifiers.shift) {
                root.file-new-video-track();
                accept
            } else if (event.text == Key.A && event.modifiers.control && event.modifiers.shift) {
                root.file-new-audio-track();
                accept
            } else if (event.text == Key.T && event.modifiers.control && event.modifiers.shift) {
                root.file-new-subtitle-track();
                accept
            } else if (event.text == Key.I && event.modifiers.control && event.modifiers.shift) {
                if (root.insert-audio-enabled) {
                    root.file-insert-audio();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.I && event.modifiers.control && event.modifiers.alt) {
                if (root.insert-subtitle-enabled) {
                    root.file-insert-subtitle();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.I && event.modifiers.control && !event.modifiers.shift) {
                root.file-insert-video();
                accept
            } else if (event.text == Key.E && event.modifiers.control && !event.modifiers.shift) {
                if (!root.export-in-progress && !root.export-preset-dialog-visible) {
                    root.file-export();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.Space) {
                root.play-pause();
                accept
            } else if (event.text == Key.LeftArrow) {
                root.seek-nudge-ms(-1000.0);
                accept
            } else if (event.text == Key.RightArrow) {
                root.seek-nudge-ms(1000.0);
                accept
            } else if (event.text == Key.Home) {
                root.seek-timeline(0.0);
                accept
            } else if (event.text == Key.End) {
                root.seek-timeline(root.duration-ms);
                accept
            } else if (event.text == Key.Z && event.modifiers.control && event.modifiers.shift) {
                if (root.redo-enabled) {
                    root.edit-redo();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.Z && event.modifiers.control && !event.modifiers.shift) {
                if (root.undo-enabled) {
                    root.edit-undo();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.B && event.modifiers.control && !event.modifiers.shift) {
                if (root.split-at-playhead-enabled) {
                    root.edit-split-at-playhead();
                    accept
                } else {
                    reject
                }
            // Ctrl+Shift+Arrow: move clip (⌘⇧ on macOS — Slint maps Command to `control`).
            } else if (event.text == Key.DownArrow && event.modifiers.control && event.modifiers.shift) {
                if (root.move-clip-down-enabled) {
                    root.edit-move-clip-down();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.UpArrow && event.modifiers.control && event.modifiers.shift) {
                if (root.move-clip-up-enabled) {
                    root.edit-move-clip-up();
                    accept
                } else {
                    reject
                }
            // Ctrl+R / ⌘R rotate right; Ctrl+Shift+R / ⌘⇧R rotate left. Needs the playhead on a primary clip.
            } else if (event.text == Key.R && event.modifiers.control && !event.modifiers.shift) {
                if (root.rotate-enabled) {
                    root.edit-rotate-right();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.R && event.modifiers.control && event.modifiers.shift) {
                if (root.rotate-enabled) {
                    root.edit-rotate-left();
                    accept
                } else {
                    reject
                }
            // QuickTime-style range markers: plain `I` / `O` / `Alt+X` (no ctrl).
            } else if (event.text == Key.I && !event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt) {
                root.edit-set-in-marker();
                accept
            } else if (event.text == Key.O && !event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt) {
                root.edit-set-out-marker();
                accept
            } else if (event.text == Key.X && event.modifiers.alt && !event.modifiers.control && !event.modifiers.shift) {
                if (root.marker-any-set) {
                    root.edit-clear-markers();
                    accept
                } else {
                    reject
                }
            } else {
                reject
            }
        }
        Rectangle {
            vertical-stretch: 1;
            width: 100%;
        VerticalBox {
        spacing: 0px;
        padding: 0px;

        Rectangle {
            background: Theme.surface-preview;
            vertical-stretch: 1;
            width: 100%;
            min-height: 200px;
            clip: true;

            preview-clip := Rectangle {
                width: 100%;
                height: 100%;
                clip: true;
                property <float> vw: self.width / 1px;
                property <float> vh: self.height / 1px;
                property <float> fw: max(1.0, root.preview-frame-width);
                property <float> fh: max(1.0, root.preview-frame-height);
                property <float> s-contain: min(vw / fw, vh / fh);
                property <float> s-cover: max(vw / fw, vh / fh);
                property <float> s-base: root.video-fit-mode == 1 ? s-cover : s-contain;
                property <float> img-w: root.preview-zoom-actual ? fw : fw * s-base * (root.preview-zoom-percent / 100.0);
                property <float> img-h: root.preview-zoom-actual ? fh : fh * s-base * (root.preview-zoom-percent / 100.0);
                Image {
                    x: (parent.width - img-w * 1px) / 2;
                    y: (parent.height - img-h * 1px) / 2;
                    width: img-w * 1px;
                    height: img-h * 1px;
                    source: root.current-frame;
                    image-fit: fill;
                }
            }

            // Full-viewport hit target for waking the transport chrome. Keep keyboard focus on `main-view-focus`
            // so Space / shortcuts work (TouchArea can take focus on click otherwise).
            TouchArea {
                width: 100%;
                height: 100%;
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.move || event.kind == PointerEventKind.down) {
                        wake-transport-chrome();
                    }
                }
                scroll-event(event) => {
                    wake-transport-chrome();
                    return reject;
                }
                clicked => {
                    main-view-focus.focus();
                }
            }

            // Compact floating transport: ≤150px tall and ≤42% of preview height (well under half the viewport).
            // Opacity is applied only to the backdrop — not the interactive root — so Slint hit-testing stays correct.
            // `z` above the full-viewport wake TouchArea so play/step/skip controls receive clicks (see lib.rs play-pause).
            if root.media-ready && (root.controls-overlay-always-visible || root.transport-chrome-opacity > 0.001): Rectangle {
                z: 100;
                property <length> chrome-max-h: min(168px, parent.height * 46 / 100);
                // v0 mock: ~60% width, centered, ~10% from bottom (QuickTime-style overlay).
                width: min(parent.width * 60 / 100, 640px);
                height: chrome-max-h;
                // Default placement: centered horizontally, ~10% up from the
                // bottom. `chrome-offset-*` lets the user drag-reposition via
                // the grip handle; clamped so the chrome can’t be dragged
                // fully off-screen (leave at least 32px visible on each edge).
                x: clamp(
                    (parent.width - self.width) / 2 + root.chrome-offset-x,
                    -self.width + 32px,
                    parent.width - 32px,
                );
                y: clamp(
                    parent.height - self.height - parent.height * 10 / 100 + root.chrome-offset-y,
                    0px,
                    parent.height - 32px,
                );
                clip: false;
                border-radius: 16px;
                Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 16px;
                    background: Theme.chrome-backdrop;
                    opacity: root.controls-overlay-always-visible ? 1.0 : root.transport-chrome-opacity;
                }
                VerticalBox {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    padding-left: 24px;
                    padding-right: 24px;
                    padding-top: 14px;
                    padding-bottom: 12px;
                    spacing: 10px;
                    alignment: center;
                    // Row 1 — matches v0: `justify-between` (grip+skip back | step+play+step | skip fwd+speed+…+tools).
                    // Reference: `assets/Knotreels.v0.ui/app/page.tsx` + https://v0-video-editing-app-ui.vercel.app/
                    HorizontalBox {
                        width: 100%;
                        alignment: space-between;
                        min-height: 48px;
                        max-height: 54px;
                        // Left: drag handle + skip to start
                        HorizontalBox {
                            spacing: 8px;
                            alignment: center;
                            // Lucide `GripHorizontal` (see `assets/Knotreels.v0.ui` / lucide-static).
                            // TouchArea wraps the icon so the handle is draggable — on press we
                            // snapshot the current chrome offset, then `moved` accumulates the
                            // pointer delta onto it. The chrome Rectangle above clamps the
                            // result so it stays partially on-screen.
                            grip-ta := TouchArea {
                                width: 22px;
                                height: 28px;
                                mouse-cursor: grab;
                                property <length> press-offset-x: 0;
                                property <length> press-offset-y: 0;
                                pointer-event(ev) => {
                                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                                        self.press-offset-x = root.chrome-offset-x;
                                        self.press-offset-y = root.chrome-offset-y;
                                    }
                                }
                                moved => {
                                    root.chrome-offset-x = self.press-offset-x + (self.mouse-x - self.pressed-x);
                                    root.chrome-offset-y = self.press-offset-y + (self.mouse-y - self.pressed-y);
                                    wake-transport-chrome();
                                }
                                Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - 14px) / 2;
                                    y: (parent.height - 14px) / 2;
                                    opacity: grip-ta.has-hover ? 0.85 : 0.4;
                                    source: @image-url("icons/lucide/grip-horizontal.svg");
                                }
                            }
                            skip-start-ta := TouchArea {
                                // TouchArea inside a HorizontalBox layout gets 0×0 preferred size unless
                                // we set it explicitly — without this the hit area is zero and the button
                                // renders but never fires. Width/height are set to comfortably cover the
                                // child icon plus a little padding for fingertip targeting.
                                width: 28px;
                                height: 28px;
                                enabled: root.media-ready;
                                accessible-role: button;
                                accessible-label: "Skip to start";
                                clicked => {
                                    main-view-focus.focus();
                                    root.seek-timeline(0.0);
                                    wake-transport-chrome();
                                }
                                Image {
                                    width: 18px;
                                    height: 18px;
                                    x: (parent.width - 18px) / 2;
                                    y: (parent.height - 18px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/skip-back.svg");
                                }
                            }
                        }
                        // Center: single-arrow step back + play + step forward (not multi-triangle rewind/ff).
                        HorizontalBox {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 22px;
                            alignment: center;
                            rw-ta := TouchArea {
                                width: 28px;
                                height: 40px;
                                enabled: root.media-ready;
                                accessible-role: button;
                                accessible-label: "Rewind";
                                clicked => {
                                    main-view-focus.focus();
                                    root.transport-rewind();
                                    wake-transport-chrome();
                                }
                                Image {
                                    width: 16px;
                                    height: 16px;
                                    x: (parent.width - 16px) / 2;
                                    y: (parent.height - 16px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/arrow-left.svg");
                                }
                            }
                            play-ta := TouchArea {
                                // Explicit size — TouchArea inside a HorizontalBox needs it or the
                                // hit area collapses to 0×0 and only the spacebar path fires.
                                width: 40px;
                                height: 40px;
                                enabled: root.media-ready;
                                accessible-role: button;
                                accessible-label: root.is-playing ? "Pause" : "Play";
                                clicked => {
                                    main-view-focus.focus();
                                    root.play-pause();
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 40px;
                                    height: 40px;
                                    border-radius: 20px;
                                    background: play-ta.pressed ? #ffffff33 : #ffffff22;
                                    clip: true;
                                    if root.is-playing: Image {
                                        width: 20px;
                                        height: 20px;
                                        x: (parent.width - 20px) / 2;
                                        y: (parent.height - 20px) / 2;
                                        source: @image-url("icons/lucide/pause.svg");
                                    }
                                    if !root.is-playing: Image {
                                        width: 20px;
                                        height: 20px;
                                        x: (parent.width - 20px) / 2 + 2px;
                                        y: (parent.height - 20px) / 2;
                                        source: @image-url("icons/lucide/play.svg");
                                    }
                                }
                            }
                            ff-ta := TouchArea {
                                width: 28px;
                                height: 40px;
                                enabled: root.media-ready;
                                accessible-role: button;
                                accessible-label: "Fast forward";
                                clicked => {
                                    main-view-focus.focus();
                                    root.transport-forward();
                                    wake-transport-chrome();
                                }
                                Image {
                                    width: 16px;
                                    height: 16px;
                                    x: (parent.width - 16px) / 2;
                                    y: (parent.height - 16px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/arrow-right.svg");
                                }
                            }
                        }
                        // Right: skip to end | speed | loop | mute | vol | fs | | tools
                        HorizontalBox {
                            spacing: 8px;
                            alignment: center;
                            skip-end-ta := TouchArea {
                                width: 28px;
                                height: 28px;
                                enabled: root.media-ready;
                                accessible-role: button;
                                accessible-label: "Skip to end";
                                clicked => {
                                    main-view-focus.focus();
                                    root.seek-timeline(root.duration-ms);
                                    wake-transport-chrome();
                                }
                                Image {
                                    width: 18px;
                                    height: 18px;
                                    x: (parent.width - 18px) / 2;
                                    y: (parent.height - 18px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/skip-forward.svg");
                                }
                            }
                            Rectangle {
                                width: 1px;
                                height: 16px;
                                background: #ffffff33;
                            }
                            speed-hit := TouchArea {
                                accessible-role: button;
                                accessible-label: "Playback speed";
                                clicked => {
                                    main-view-focus.focus();
                                    wake-transport-chrome();
                                }
                                HorizontalBox {
                                    spacing: 2px;
                                    alignment: center;
                                    padding-left: 4px;
                                    padding-right: 2px;
                                    padding-top: 2px;
                                    padding-bottom: 2px;
                                    Text {
                                        text: root.transport-rate-label;
                                        color: #ffffffb3;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Image {
                                        width: 10px;
                                        height: 10px;
                                        opacity: 0.55;
                                        source: @image-url("icons/lucide/chevron-down.svg");
                                    }
                                }
                            }
                            loop-ta := TouchArea {
                                width: 28px;
                                height: 24px;
                                accessible-role: button;
                                accessible-label: root.loop-playback ? "Disable loop playback" : "Enable loop playback";
                                clicked => {
                                    main-view-focus.focus();
                                    root.view-toggle-loop();
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    border-radius: 4px;
                                    background: root.loop-playback ? #0a84ff4d : transparent;
                                    HorizontalBox {
                                        padding-left: 4px;
                                        padding-right: 4px;
                                        padding-top: 2px;
                                        padding-bottom: 2px;
                                        alignment: center;
                                        Image {
                                            width: 14px;
                                            height: 14px;
                                            opacity: root.loop-playback ? 1.0 : 0.7;
                                            source: @image-url("icons/lucide/repeat.svg");
                                            // Lucide SVGs use `stroke="currentColor"`, so a transparent
                                            // colorize value made the icon vanish entirely. Always tint
                                            // to a visible color; the background pill below already
                                            // signals the active state.
                                            colorize: root.loop-playback ? Theme.accent-blue : #ffffff;
                                        }
                                    }
                                }
                            }
                            mute-ta := TouchArea {
                                width: 20px;
                                height: 20px;
                                accessible-role: button;
                                accessible-label: root.volume-percent < 0.5 ? "Unmute" : "Mute";
                                clicked => {
                                    main-view-focus.focus();
                                    if (root.volume-percent < 0.5) {
                                        root.volume-percent = 85.0;
                                    } else {
                                        root.volume-percent = 0.0;
                                    }
                                    root.volume-changed(root.volume-percent);
                                    wake-transport-chrome();
                                }
                                if root.volume-percent < 0.5: Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - 14px) / 2;
                                    y: (parent.height - 14px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/volume-x.svg");
                                }
                                if root.volume-percent >= 0.5: Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - 14px) / 2;
                                    y: (parent.height - 14px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/volume-2.svg");
                                }
                            }
                            Slider {
                                width: 48px;
                                height: 14px;
                                minimum: 0;
                                maximum: 100;
                                value: root.volume-percent;
                                accessible-label: "Volume";
                                changed(v) => {
                                    main-view-focus.focus();
                                    root.volume-percent = v;
                                    root.volume-changed(v);
                                    wake-transport-chrome();
                                }
                            }
                            fs-ta := TouchArea {
                                width: 20px;
                                height: 20px;
                                accessible-role: button;
                                accessible-label: root.window-fullscreen ? "Exit fullscreen" : "Enter fullscreen";
                                clicked => {
                                    main-view-focus.focus();
                                    root.view-toggle-fullscreen();
                                    wake-transport-chrome();
                                }
                                if root.window-fullscreen: Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - 14px) / 2;
                                    y: (parent.height - 14px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/minimize.svg");
                                }
                                if !root.window-fullscreen: Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - 14px) / 2;
                                    y: (parent.height - 14px) / 2;
                                    opacity: 0.7;
                                    source: @image-url("icons/lucide/maximize.svg");
                                }
                            }
                            Rectangle {
                                width: 1px;
                                height: 16px;
                                background: #ffffff33;
                            }
                            tools-ta := TouchArea {
                                width: 28px;
                                height: 24px;
                                accessible-role: button;
                                accessible-label: root.tools-popup-open ? "Close tools menu" : "Open tools menu";
                                clicked => {
                                    main-view-focus.focus();
                                    root.tools-popup-open = !root.tools-popup-open;
                                    if (!root.tools-popup-open) {
                                        root.tools-effects-submenu-open = false;
                                    }
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    border-radius: 4px;
                                    background: root.tools-popup-open ? #0a84ff4d : transparent;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        x: (parent.width - 14px) / 2;
                                        y: (parent.height - 14px) / 2;
                                        opacity: root.tools-popup-open ? 1.0 : 0.7;
                                        source: @image-url("icons/lucide/chevrons-right.svg");
                                        // Same colorize-transparent bug as loop-ta — the Lucide
                                        // SVG strokes with `currentColor`, so transparent made
                                        // the icon disappear. Tint white when closed, accent-blue
                                        // when the popup is open.
                                        colorize: root.tools-popup-open ? Theme.accent-blue : #ffffff;
                                    }
                                }
                            }
                        }
                    }
                        HorizontalBox {
                            padding-left: 0px;
                            padding-right: 0px;
                            spacing: 12px;
                            alignment: center;
                            min-height: 32px;
                            max-height: 38px;
                            property <length> scrub-row-w: self.width;
                            Text {
                                text: root.time-elapsed;
                                color: #ffffff;
                                font-size: 11px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                width: 56px;
                                overflow: elide;
                            }
                            scrub-wrap := Rectangle {
                                // Wrapper for the Slider + yellow In/Out drag handles. Handle
                                // positions are driven by `marker-in-ms` / `marker-out-ms` (ms
                                // sentinel `-1` = unset → hidden); `edit-drag-*-marker-ms`
                                // callbacks fire while the user drags a handle.
                                width: max(40px, scrub-row-w - 124px);
                                height: 14px;
                                Slider {
                                    width: 100%;
                                    height: 100%;
                                    enabled: root.media-ready;
                                    minimum: 0;
                                    maximum: max(root.duration-ms, 1);
                                    step: 0;
                                    value <=> root.playhead-ms;
                                    accessible-label: "Timeline scrub bar";
                                    changed(v) => {
                                        main-view-focus.focus();
                                        root.seek-timeline(v);
                                        wake-transport-chrome();
                                    }
                                }
                                // Range fill between In and Out (yellow at 25% alpha per v0
                                // spec). Sits on top of the slider track but *below* the handles
                                // so the handle grips remain the primary click targets.
                                Rectangle {
                                    visible: root.marker-in-ms >= 0 && root.marker-out-ms >= 0 && root.duration-ms > 0;
                                    height: 3px;
                                    y: parent.height - self.height - 1px;
                                    x: parent.width * (root.marker-in-ms / max(root.duration-ms, 1));
                                    width: parent.width * ((root.marker-out-ms - root.marker-in-ms) / max(root.duration-ms, 1));
                                    background: Theme.trim-range-fill;
                                }
                                // --- In handle (yellow, QuickTime-style, rounded left) ---
                                in-handle := Rectangle {
                                    visible: root.marker-in-ms >= 0 && root.duration-ms > 0;
                                    width: 10px;
                                    height: 100%;
                                    background: Theme.trim-handle;
                                    border-radius: 3px;
                                    // `border-top-right-radius` etc. aren't supported in 1.16,
                                    // so a symmetric radius is close enough visually. The
                                    // asymmetry trick (rounded outward edge only) would need a
                                    // separate clip-parent; skipping for scope.
                                    x: parent.width * (root.marker-in-ms / max(root.duration-ms, 1)) - self.width / 2;
                                    y: 0;
                                    // Three black grip dots (spec: vertical grip lines).
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        padding-left: 0;
                                        padding-right: 0;
                                        for i in 3: Rectangle {
                                            width: 4px;
                                            height: 1px;
                                            background: Theme.trim-handle-grip;
                                        }
                                    }
                                    in-handle-touch := TouchArea {
                                        mouse-cursor: ew-resize;
                                        accessible-role: button;
                                        accessible-label: "In marker — drag to set trim start";
                                        moved => {
                                            if (self.pressed && root.duration-ms > 0) {
                                                // `self.mouse-x` is pointer x within this TouchArea
                                                // (0..in-handle.width). `in-handle.x` is the handle's
                                                // top-left in wrapper coords. Their sum is the pointer's
                                                // x within the wrapper → convert to ms + clamp so the In
                                                // handle can never cross the Out handle.
                                                root.edit-drag-in-marker-ms(
                                                    min(
                                                        root.marker-out-ms >= 0
                                                            ? max(0, root.marker-out-ms - 10)
                                                            : root.duration-ms,
                                                        max(0, (in-handle.x + self.mouse-x) / max(scrub-wrap.width, 1px) * root.duration-ms)
                                                    )
                                                );
                                            }
                                        }
                                    }
                                }
                                // --- Out handle (yellow, QuickTime-style, rounded right) ---
                                out-handle := Rectangle {
                                    visible: root.marker-out-ms >= 0 && root.duration-ms > 0;
                                    width: 10px;
                                    height: 100%;
                                    background: Theme.trim-handle;
                                    border-radius: 3px;
                                    x: parent.width * (root.marker-out-ms / max(root.duration-ms, 1)) - self.width / 2;
                                    y: 0;
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        padding-left: 0;
                                        padding-right: 0;
                                        for i in 3: Rectangle {
                                            width: 4px;
                                            height: 1px;
                                            background: Theme.trim-handle-grip;
                                        }
                                    }
                                    out-handle-touch := TouchArea {
                                        mouse-cursor: ew-resize;
                                        accessible-role: button;
                                        accessible-label: "Out marker — drag to set trim end";
                                        moved => {
                                            if (self.pressed && root.duration-ms > 0) {
                                                root.edit-drag-out-marker-ms(
                                                    max(
                                                        root.marker-in-ms >= 0
                                                            ? min(root.duration-ms, root.marker-in-ms + 10)
                                                            : 0,
                                                        min(root.duration-ms, (out-handle.x + self.mouse-x) / max(scrub-wrap.width, 1px) * root.duration-ms)
                                                    )
                                                );
                                            }
                                        }
                                    }
                                }
                            }
                            Text {
                                text: root.time-total;
                                color: #ffffff99;
                                font-size: 11px;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                                width: 56px;
                                overflow: elide;
                            }
                        }
                    }
                // Tools popup (v0: `ChevronsRight` → panel above; Effects opens Face Swap / Enhance / Remove BG).
                if root.tools-popup-open: Rectangle {
                    width: 176px;
                    x: parent.width - self.width - 24px;
                    y: -self.height - 10px;
                    border-radius: 8px;
                    background: #2d2d2d;
                    clip: false;
                    // Effects submenu sits to the left, bottom-aligned with this panel.
                    if root.tools-effects-submenu-open: Rectangle {
                        width: 152px;
                        x: -self.width - 6px;
                        y: parent.height - self.height;
                        border-radius: 8px;
                        background: #2d2d2d;
                        VerticalBox {
                            padding-top: 6px;
                            padding-bottom: 6px;
                            padding-left: 0px;
                            padding-right: 0px;
                            spacing: 0px;
                            // Effects submenu items — clean lucide icons, full-row hover,
                            // left-aligned content (standard menu convention). Rectangle uses
                            // width:100% so the hover background spans the whole panel width.
                            eff-sub-swap := TouchArea {
                                height: 30px;
                                clicked => {
                                    main-view-focus.focus();
                                    root.effect-face-swap();
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    background: eff-sub-swap.has-hover ? Theme.accent-blue : transparent;
                                    HorizontalBox {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        alignment: start;
                                        Image {
                                            width: 14px;
                                            height: 14px;
                                            y: (parent.height - 14px) / 2;
                                            source: @image-url("icons/lucide/user.svg");
                                            colorize: #ffffff;
                                        }
                                        Text {
                                            text: "Face Swap";
                                            color: #ffffff;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            eff-sub-enh := TouchArea {
                                height: 30px;
                                clicked => {
                                    main-view-focus.focus();
                                    root.effect-face-enhance();
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    background: eff-sub-enh.has-hover ? Theme.accent-blue : transparent;
                                    HorizontalBox {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        alignment: start;
                                        Image {
                                            width: 14px;
                                            height: 14px;
                                            y: (parent.height - 14px) / 2;
                                            source: @image-url("icons/lucide/sparkles.svg");
                                            colorize: #ffffff;
                                        }
                                        Text {
                                            text: "Face Enhance";
                                            color: #ffffff;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            eff-sub-rm := TouchArea {
                                height: 30px;
                                clicked => {
                                    main-view-focus.focus();
                                    root.effect-remove-background();
                                    wake-transport-chrome();
                                }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    background: eff-sub-rm.has-hover ? Theme.accent-blue : transparent;
                                    HorizontalBox {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        alignment: start;
                                        Image {
                                            width: 14px;
                                            height: 14px;
                                            y: (parent.height - 14px) / 2;
                                            source: @image-url("icons/lucide/eraser.svg");
                                            colorize: #ffffff;
                                        }
                                        Text {
                                            text: "Remove BG";
                                            color: #ffffff;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                height: 1px;
                                width: 100%;
                                background: #4a4a4a;
                            }
                            Rectangle {
                                // Disabled "coming soon" row — greyed out, no TouchArea.
                                height: 30px;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/zoom-in.svg");
                                        colorize: #6e6e6e;
                                    }
                                    Text {
                                        text: "AI Upscale";
                                        color: #6e6e6e;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    VerticalBox {
                        padding-top: 6px;
                        padding-bottom: 6px;
                        padding-left: 0px;
                        padding-right: 0px;
                        spacing: 0px;
                        // Main tools-popup rows. Lucide SVG icons (tinted white via
                        // `colorize`) replace the earlier hand-drawn `Path` commands —
                        // those rendered at 14×14 as jagged untuned strokes. Each row
                        // uses `width: 100%` on the hover-bg Rectangle so the highlight
                        // fills the full popup width, and `alignment: start` on the
                        // HorizontalBox for a conventional left-aligned menu.
                        tp-mw := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-mw.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/wand-2.svg");
                                        colorize: #ffffff;
                                    }
                                    Text {
                                        text: "Magic Wand";
                                        color: #ffffff;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        tp-lasso := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-lasso.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/scissors.svg");
                                        colorize: #ffffff;
                                    }
                                    Text {
                                        text: "Lasso Select";
                                        color: #ffffff;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        tp-crop := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-crop.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/crop.svg");
                                        colorize: #ffffff;
                                    }
                                    Text {
                                        text: "Crop";
                                        color: #ffffff;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        Rectangle {
                            height: 1px;
                            width: 100%;
                            background: #4a4a4a;
                        }
                        tp-con := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-con.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/eye.svg");
                                        colorize: #ffffff;
                                    }
                                    Text {
                                        text: "Contrast";
                                        color: #ffffff;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        tp-light := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-light.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: start;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        y: (parent.height - 14px) / 2;
                                        source: @image-url("icons/lucide/sparkles.svg");
                                        colorize: #ffffff;
                                    }
                                    Text {
                                        text: "Lighting";
                                        color: #ffffff;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        Rectangle {
                            height: 1px;
                            width: 100%;
                            background: #4a4a4a;
                        }
                        tp-effects := TouchArea {
                            height: 30px;
                            clicked => {
                                main-view-focus.focus();
                                root.tools-effects-submenu-open = !root.tools-effects-submenu-open;
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: tp-effects.has-hover ? #4a4a4a : transparent;
                                HorizontalBox {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    alignment: space-between;
                                    HorizontalBox {
                                        spacing: 8px;
                                        alignment: start;
                                        Image {
                                            width: 14px;
                                            height: 14px;
                                            y: (parent.height - 14px) / 2;
                                            source: @image-url("icons/lucide/layers.svg");
                                            colorize: #ffffff;
                                        }
                                        Text {
                                            text: "Effects";
                                            color: #ffffff;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    // Submenu affordance — right-pointing chevron using the
                                    // existing lucide asset (rotated via transform-origin for
                                    // correct kerning at 10×10). `chevron-down` rotated −90°
                                    // reads as `>` so we don't ship a second SVG.
                                    Image {
                                        width: 10px;
                                        height: 10px;
                                        y: (parent.height - 10px) / 2;
                                        transform-rotation: -90deg;
                                        source: @image-url("icons/lucide/chevron-down.svg");
                                        colorize: #ffffff;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Multi-row timeline summary (data from Rust — see `video_track_row_labels` / `audio_track_row_labels`).
        // Layout aligns with v0 mock: padded strip under the preview, before the status footer.
        // Hidden entirely when **View → Video/Audio/Subtitle Tracks** are all off (v0-style toggles).
        if root.media-ready && (root.view-show-video-tracks || root.view-show-audio-tracks || root.view-show-subtitle-tracks): Rectangle {
            vertical-stretch: 0;
            width: 100%;
            background: Theme.surface-timeline;
            Rectangle {
                height: 1px;
                width: 100%;
                y: 0;
                background: Theme.border-subtle;
            }
            VerticalBox {
                padding-left: 8px;
                // Extra right-side gap so the timeline strip doesn't run
                // flush to the window edge — makes drop targets and trim
                // handles past the last clip reachable with a mouse. The
                // FilmstripLane itself reserves an additional 32 px drag
                // strip inside the lane body (see `padding-right` there).
                padding-right: 16px;
                padding-top: 12px;
                padding-bottom: 12px;
                spacing: 8px;
                // VIDEO row — track-type icon sits on the same row as the first
                // lane (V1), with the `+ add track` button directly beneath it.
                // Uppercase title dropped; sections are divided by thin
                // Theme.border-subtle separators (see below).
                if root.view-show-video-tracks: HorizontalBox {
                    spacing: 6px;
                    alignment: start;
                    padding: 0;
                    // Left column: icon (aligned with the 48px first-lane row) +
                    // `+ add track` button stacked below. The icon cell is the
                    // exact height of a FilmstripLane row (48px) so the icon is
                    // centered on the first lane; the + button sits on its own
                    // row right underneath.
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        alignment: start;
                        Rectangle {
                            width: 28px;
                            height: 48px;
                            Image {
                                width: 16px;
                                height: 16px;
                                source: @image-url("icons/lucide/film.svg");
                                colorize: Theme.clip-video;
                            }
                        }
                        track-add-video := TouchArea {
                            width: 28px;
                            height: 28px;
                            accessible-role: button;
                            accessible-label: "Add video track";
                            clicked => {
                                main-view-focus.focus();
                                root.file-new-video-track();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: track-add-video.has-hover ? Theme.background-hover : Theme.background-secondary;
                                HorizontalBox {
                                    width: 100%;
                                    height: 100%;
                                    alignment: center;
                                    Text {
                                        text: "+";
                                        color: Theme.accent-blue;
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    // Right column: the FilmstripLane rows. Mirrors the prior
                    // section VerticalBox's 10px spacing so lanes stack the
                    // same way.
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        horizontal-stretch: 1;
                        if root.tl_video_track_count >= 1: FilmstripLane {
                            lane-label: "V1";
                            lane-accent: Theme.clip-video;
                            chips: root.tl_vrow0;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: root.tl_video_project_track_count > 1 && 0 < root.tl_video_project_track_count;
                            track-delete => {
                                root.delete-video-track(0);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_video_track_count >= 2: FilmstripLane {
                            lane-label: "V2";
                            lane-accent: Theme.clip-video;
                            chips: root.tl_vrow1;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: root.tl_video_project_track_count > 1 && 1 < root.tl_video_project_track_count;
                            track-delete => {
                                root.delete-video-track(1);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_video_track_count >= 3: FilmstripLane {
                            lane-label: "V3";
                            lane-accent: Theme.clip-video;
                            chips: root.tl_vrow2;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: root.tl_video_project_track_count > 1 && 2 < root.tl_video_project_track_count;
                            track-delete => {
                                root.delete-video-track(2);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_video_track_count >= 4: FilmstripLane {
                            lane-label: "V4";
                            lane-accent: Theme.clip-video;
                            chips: root.tl_vrow3;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: root.tl_video_project_track_count > 1 && 3 < root.tl_video_project_track_count;
                            track-delete => {
                                root.delete-video-track(3);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                    }
                }
                // Separator between VIDEO and whatever section follows. Only
                // rendered when the video section is visible AND at least one
                // of the lower sections (audio / subtitle) is visible — this
                // way a single-visible-section layout stays clean.
                if root.view-show-video-tracks && (root.view-show-audio-tracks || root.view-show-subtitle-tracks): Rectangle {
                    height: 1px;
                    background: Theme.border-subtle;
                }
                // AUDIO row — cyan music icon on the first-lane row, `+` below.
                if root.view-show-audio-tracks: HorizontalBox {
                    spacing: 6px;
                    alignment: start;
                    padding: 0;
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        alignment: start;
                        Rectangle {
                            width: 28px;
                            height: 48px;
                            Image {
                                width: 16px;
                                height: 16px;
                                source: @image-url("icons/lucide/music.svg");
                                colorize: Theme.clip-audio;
                            }
                        }
                        track-add-audio := TouchArea {
                            width: 28px;
                            height: 28px;
                            accessible-role: button;
                            accessible-label: "Add audio track";
                            clicked => {
                                main-view-focus.focus();
                                root.file-new-audio-track();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: track-add-audio.has-hover ? Theme.background-hover : Theme.background-secondary;
                                HorizontalBox {
                                    width: 100%;
                                    height: 100%;
                                    alignment: center;
                                    Text {
                                        text: "+";
                                        color: Theme.accent-blue;
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        horizontal-stretch: 1;
                        // Waveform / peak drawing on audio lanes is intentionally last — after clip chips, footer, and other v0 alignment (see **`docs/phases-ui.md`**).
                        if root.tl_audio_track_count >= 1: FilmstripLane {
                            lane-label: "A1";
                            lane-accent: Theme.clip-audio;
                            chips: root.tl_arow0;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: 0 < root.tl_audio_project_track_count;
                            track-delete => {
                                root.delete-audio-track(0);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_audio_track_count >= 2: FilmstripLane {
                            lane-label: "A2";
                            lane-accent: Theme.clip-audio;
                            chips: root.tl_arow1;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: 1 < root.tl_audio_project_track_count;
                            track-delete => {
                                root.delete-audio-track(1);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_audio_track_count >= 3: FilmstripLane {
                            lane-label: "A3";
                            lane-accent: Theme.clip-audio;
                            chips: root.tl_arow2;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: 2 < root.tl_audio_project_track_count;
                            track-delete => {
                                root.delete-audio-track(2);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                        if root.tl_audio_track_count >= 4: FilmstripLane {
                            lane-label: "A4";
                            lane-accent: Theme.clip-audio;
                            chips: root.tl_arow3;
                            placeholder-stripe: root.timeline-placeholder-stripe;
                            playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                            delete-enabled: 3 < root.tl_audio_project_track_count;
                            track-delete => {
                                root.delete-audio-track(3);
                            }
                            clip-trim-commit(id, edge, r) => {
                                root.clip-trim-commit(id, edge, r);
                            }
                            seek-ratio(r) => {
                                if (root.media-ready && root.duration-ms > 0) {
                                    root.seek-timeline(r * root.duration-ms);
                                }
                            }
                        }
                    }
                }
                // Separator between AUDIO and SUBTITLES.
                if root.view-show-audio-tracks && root.view-show-subtitle-tracks: Rectangle {
                    height: 1px;
                    background: Theme.border-subtle;
                }
                // SUBTITLES — neutral type icon on first-lane row, `+` below —
                // container streams (single-media) and/or project
                // [`TrackKind::Subtitle`] lanes.
                if root.view-show-subtitle-tracks: HorizontalBox {
                    spacing: 6px;
                    alignment: start;
                    padding: 0;
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        alignment: start;
                        Rectangle {
                            width: 28px;
                            height: 48px;
                            Image {
                                width: 16px;
                                height: 16px;
                                source: @image-url("icons/lucide/type.svg");
                                colorize: Theme.clip-subtitle;
                            }
                        }
                        track-add-subtitle := TouchArea {
                            width: 28px;
                            height: 28px;
                            accessible-role: button;
                            accessible-label: "Add subtitle track";
                            clicked => {
                                main-view-focus.focus();
                                root.file-new-subtitle-track();
                                wake-transport-chrome();
                            }
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: track-add-subtitle.has-hover ? Theme.background-hover : Theme.background-secondary;
                                HorizontalBox {
                                    width: 100%;
                                    height: 100%;
                                    alignment: center;
                                    Text {
                                        text: "+";
                                        color: Theme.accent-blue;
                                        font-size: 18px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    VerticalBox {
                        spacing: 10px;
                        padding: 0;
                        horizontal-stretch: 1;
                        if root.tl_subtitle_track_count >= 1: FilmstripLane {
                        lane-label: "S1";
                        lane-accent: Theme.clip-subtitle;
                        chips: root.tl_srow0;
                        placeholder-stripe: root.timeline-placeholder-stripe;
                        playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                        delete-enabled: 0 < root.tl_subtitle_project_track_count;
                        track-delete => {
                            root.delete-subtitle-track(0);
                        }
                        clip-trim-commit(id, edge, r) => {
                            root.clip-trim-commit(id, edge, r);
                        }
                        seek-ratio(r) => {
                            if (root.media-ready && root.duration-ms > 0) {
                                root.seek-timeline(r * root.duration-ms);
                            }
                        }
                    }
                    if root.tl_subtitle_track_count >= 2: FilmstripLane {
                        lane-label: "S2";
                        lane-accent: Theme.clip-subtitle;
                        chips: root.tl_srow1;
                        placeholder-stripe: root.timeline-placeholder-stripe;
                        playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                        delete-enabled: 1 < root.tl_subtitle_project_track_count;
                        track-delete => {
                            root.delete-subtitle-track(1);
                        }
                        clip-trim-commit(id, edge, r) => {
                            root.clip-trim-commit(id, edge, r);
                        }
                        seek-ratio(r) => {
                            if (root.media-ready && root.duration-ms > 0) {
                                root.seek-timeline(r * root.duration-ms);
                            }
                        }
                    }
                    if root.tl_subtitle_track_count >= 3: FilmstripLane {
                        lane-label: "S3";
                        lane-accent: Theme.clip-subtitle;
                        chips: root.tl_srow2;
                        placeholder-stripe: root.timeline-placeholder-stripe;
                        playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                        delete-enabled: 2 < root.tl_subtitle_project_track_count;
                        track-delete => {
                            root.delete-subtitle-track(2);
                        }
                        clip-trim-commit(id, edge, r) => {
                            root.clip-trim-commit(id, edge, r);
                        }
                        seek-ratio(r) => {
                            if (root.media-ready && root.duration-ms > 0) {
                                root.seek-timeline(r * root.duration-ms);
                            }
                        }
                    }
                    if root.tl_subtitle_track_count >= 4: FilmstripLane {
                        lane-label: "S4";
                        lane-accent: Theme.clip-subtitle;
                        chips: root.tl_srow3;
                        placeholder-stripe: root.timeline-placeholder-stripe;
                        playhead-ratio: root.duration-ms > 0 ? root.playhead-ms / root.duration-ms : 0;
                        delete-enabled: 3 < root.tl_subtitle_project_track_count;
                        track-delete => {
                            root.delete-subtitle-track(3);
                        }
                        clip-trim-commit(id, edge, r) => {
                            root.clip-trim-commit(id, edge, r);
                        }
                        seek-ratio(r) => {
                            if (root.media-ready && root.duration-ms > 0) {
                                root.seek-timeline(r * root.duration-ms);
                            }
                        }
                    }
                    }
                }
            }
        }

        // Below the preview: only when **View → Show Status** is on (and there is something to show).
        // Use `if` (not `visible:`) so the strip takes no layout space when off — preview fills to the window bottom.
        if root.view-show-status && (root.export-in-progress || root.status-text != "" || root.footer-visible): Rectangle {
            background: Theme.background-secondary;
            vertical-stretch: 0;
            clip: true;
            Rectangle {
                height: 1px;
                width: 100%;
                background: Theme.border-subtle;
            }
            VerticalBox {
                padding: 0;
                spacing: 0;
                Rectangle {
                    height: root.export-in-progress ? 4px : 0px;
                    background: Theme.background-primary;
                    clip: true;
                    Rectangle {
                        height: 4px;
                        width: parent.width * min(1, max(0, root.export-progress));
                        background: Theme.accent-blue;
                    }
                }
                HorizontalBox {
                    visible: root.status-text != "";
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    spacing: 10px;
                    alignment: center;
                    min-height: 30px;
                    Text {
                        text: root.status-text;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        wrap: word-wrap;
                    }
                }
                HorizontalBox {
                    visible: root.status-text == "" && root.footer-visible;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 12px;
                    alignment: space-between;
                    min-height: 34px;
                    Text {
                        text: root.footer-codec-line;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        wrap: no-wrap;
                        horizontal-stretch: 0;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.footer-path-line;
                        color: Theme.text-tertiary;
                        font-size: 10px;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    HorizontalBox {
                        spacing: 6px;
                        alignment: end;
                        horizontal-stretch: 0;
                        Text {
                            visible: !root.footer-unsaved;
                            text: "✓";
                            color: #30d158;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.footer-save-line;
                            color: root.footer-unsaved ? Theme.accent-orange : #30d158;
                            font-size: 11px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                        }
                    }
                }
            }
        }
        }
        }

        footer-sync-timer := Timer {
            interval: 350ms;
            running: root.footer-visible && root.view-show-status && root.is-playing;
            triggered => {
                root.footer-refresh();
            }
        }

        if root.export-preset-dialog-visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: rgba(0, 0, 0, 55%);
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.export-preset-cancel();
                }
            }
            VerticalBox {
                alignment: center;
                vertical-stretch: 1;
                horizontal-stretch: 1;
                HorizontalBox {
                    alignment: center;
                    horizontal-stretch: 1;
                    Rectangle {
                        width: min(parent.width * 0.92, 440px);
                        background: #2e2e36;
                        border-radius: 8px;
                        VerticalBox {
                            padding: 16px;
                            spacing: 10px;
                            Text {
                                text: "Export preset";
                                color: #eee;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            Text {
                                text: "Choose how ffmpeg writes the file (see Help → Supported formats).";
                                color: #888;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            VerticalBox {
                                spacing: 6px;
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MP4 remux";
                                    clicked => {
                                        root.export-preset-index = 0;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 0 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 0 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MP4 — remux (stream copy + faststart)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Fastest when codecs are compatible.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MP4 H.264 AAC";
                                    clicked => {
                                        root.export-preset-index = 1;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 1 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 1 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MP4 — H.264 + AAC (re-encode)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Use when remux fails or you need a fixed web/mobile target.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MP4 HEVC AAC";
                                    clicked => {
                                        root.export-preset-index = 2;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 2 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 2 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MP4 — HEVC (H.265) + AAC (re-encode)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Smaller files at equal quality; iOS-native (hvc1 tag).";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: WebM VP8 Opus";
                                    clicked => {
                                        root.export-preset-index = 3;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 3 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 3 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "WebM — VP8 + Opus (re-encode)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Fastest WebM encode; widest browser support.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: WebM VP9 Opus";
                                    clicked => {
                                        root.export-preset-index = 4;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 4 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 4 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "WebM — VP9 + Opus (re-encode)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Better compression than VP8; slower encode.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: WebM AV1 Opus";
                                    clicked => {
                                        root.export-preset-index = 5;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 5 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 5 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "WebM — AV1 + Opus (re-encode)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Best compression; much slower encode (libaom-av1).";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MKV remux";
                                    clicked => {
                                        root.export-preset-index = 6;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 6 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 6 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MKV — remux (stream copy)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Flexible container; good for mixed codecs.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MOV remux";
                                    clicked => {
                                        root.export-preset-index = 7;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 7 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 7 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MOV — remux (stream copy)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "QuickTime container; pro-handoff. Accepts H.264 / HEVC + AAC / PCM.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MOV ProRes 422 HQ plus PCM";
                                    clicked => {
                                        root.export-preset-index = 8;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 8 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 8 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MOV — ProRes 422 HQ + PCM (intermediate)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Pro handoff to Final Cut / DaVinci / Premiere; visually lossless, large files.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: MKV DNxHR HQ plus PCM";
                                    clicked => {
                                        root.export-preset-index = 9;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 9 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 9 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "MKV — DNxHR HQ + PCM (intermediate)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Avid/resolve-friendly intermediate; visually lossless, large files.";
                                                color: #888;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: Animated GIF sharp";
                                    clicked => {
                                        root.export-preset-index = 10;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 10 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 10 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "GIF — Sharp (720 px, 24 fps, 256 colors)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Best quality; large files. Audio will be removed — GIFs are silent.";
                                                color: #e8a94a;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: Animated GIF good";
                                    clicked => {
                                        root.export-preset-index = 11;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 11 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 11 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "GIF — Good (540 px, 20 fps, 128 colors)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Balanced quality and size. Audio will be removed — GIFs are silent.";
                                                color: #e8a94a;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: Animated GIF share";
                                    clicked => {
                                        root.export-preset-index = 12;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 12 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 12 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "GIF — Share (480 px, 15 fps, 96 colors)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Chat/forum friendly size. Audio will be removed — GIFs are silent.";
                                                color: #e8a94a;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                TouchArea {
                                    accessible-role: button;
                                    accessible-label: "Export preset: Animated GIF tiny";
                                    clicked => {
                                        root.export-preset-index = 13;
                                    }
                                    Rectangle {
                                        background: root.export-preset-index == 13 ? #3a3a48 : #2a2a32;
                                        border-width: 1px;
                                        border-color: root.export-preset-index == 13 ? #4a9eff : #444;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: "GIF — Tiny (320 px, 12 fps, 64 colors)";
                                                color: #ddd;
                                                font-size: 12px;
                                                font-weight: 600;
                                            }
                                            Text {
                                                text: "Smallest files; noticeable banding. Audio will be removed — GIFs are silent.";
                                                color: #e8a94a;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                            }
                            HorizontalBox {
                                spacing: 10px;
                                alignment: end;
                                Button {
                                    text: "Cancel";
                                    clicked => {
                                        root.export-preset-cancel();
                                    }
                                }
                                Button {
                                    text: "Next…";
                                    clicked => {
                                        root.export-preset-confirm();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.export-in-progress: Rectangle {
            width: parent.width;
            height: parent.height;
            background: rgba(0, 0, 0, 60%);
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => { }
            }
            VerticalBox {
                alignment: center;
                vertical-stretch: 1;
                horizontal-stretch: 1;
                HorizontalBox {
                    alignment: center;
                    horizontal-stretch: 1;
                    Rectangle {
                        width: min(parent.width * 0.88, 420px);
                        background: #2e2e36;
                        border-radius: 8px;
                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { }
                        }
                        VerticalBox {
                            padding: 18px;
                            spacing: 14px;
                            Text {
                                text: "Exporting";
                                color: #eee;
                                font-size: 16px;
                                font-weight: 700;
                            }
                            Text {
                                text: "Writing the file to disk — you can cancel and keep editing.";
                                color: #888;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            Rectangle {
                                height: 10px;
                                background: #1a1a20;
                                border-radius: 5px;
                                clip: true;
                                Rectangle {
                                    height: 10px;
                                    width: parent.width * min(1, max(0, root.export-progress));
                                    background: #4a9eff;
                                    border-radius: 5px;
                                }
                            }
                            Text {
                                text: round(root.export-progress * 1000) / 10 + "%";
                                color: #ccc;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                            HorizontalBox {
                                alignment: center;
                                horizontal-stretch: 1;
                                Button {
                                    text: "Cancel export";
                                    clicked => {
                                        root.export-cancel();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.trim-sheet-visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: rgba(0, 0, 0, 55%);
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.trim-cancel();
                }
            }
            VerticalBox {
                alignment: center;
                vertical-stretch: 1;
                horizontal-stretch: 1;
                HorizontalBox {
                    alignment: center;
                    horizontal-stretch: 1;
                    Rectangle {
                        width: min(parent.width * 0.92, 440px);
                        background: #2e2e36;
                        border-radius: 8px;
                        TouchArea {
                            // Swallow clicks inside the card so the backdrop doesn't close the sheet.
                            width: 100%;
                            height: 100%;
                        }
                        VerticalBox {
                            padding: 16px;
                            spacing: 10px;
                            Text {
                                text: "Trim Clip";
                                color: #eee;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            Text {
                                text: root.trim-source-duration-s > 0
                                    ? "Source duration: " + round(root.trim-source-duration-s * 1000) / 1000 + " s. Begin and end are in source-file seconds."
                                    : "Begin and end are in source-file seconds (source duration unknown — ffmpeg will clamp on seek).";
                                color: #888;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 10px;
                                VerticalBox {
                                    spacing: 4px;
                                    Text {
                                        text: "Begin (s)";
                                        color: #bbb;
                                        font-size: 11px;
                                    }
                                    trim-begin-input := LineEdit {
                                        text: round(root.trim-begin-s * 1000) / 1000;
                                        input-type: decimal;
                                    }
                                }
                                VerticalBox {
                                    spacing: 4px;
                                    Text {
                                        text: "End (s)";
                                        color: #bbb;
                                        font-size: 11px;
                                    }
                                    trim-end-input := LineEdit {
                                        text: round(root.trim-end-s * 1000) / 1000;
                                        input-type: decimal;
                                    }
                                }
                            }
                            if root.trim-error != "": Text {
                                text: root.trim-error;
                                color: #ff8080;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 10px;
                                alignment: end;
                                Button {
                                    text: "Cancel";
                                    clicked => {
                                        root.trim-cancel();
                                    }
                                }
                                Button {
                                    text: "Trim";
                                    primary: true;
                                    clicked => {
                                        root.trim-confirm(
                                            trim-begin-input.text.to-float(),
                                            trim-end-input.text.to-float(),
                                        );
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.gain-sheet-visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: rgba(0, 0, 0, 55%);
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.gain-cancel();
                }
            }
            VerticalBox {
                alignment: center;
                vertical-stretch: 1;
                horizontal-stretch: 1;
                HorizontalBox {
                    alignment: center;
                    horizontal-stretch: 1;
                    Rectangle {
                        width: min(parent.width * 0.92, 440px);
                        background: #2e2e36;
                        border-radius: 8px;
                        TouchArea {
                            // Swallow clicks inside the card so the backdrop doesn't close the sheet.
                            width: 100%;
                            height: 100%;
                        }
                        VerticalBox {
                            padding: 16px;
                            spacing: 10px;
                            Text {
                                text: "Audio Lane Gain";
                                color: #eee;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            Text {
                                text: root.gain-sheet-max-lane > 0
                                    ? "Lane 1–" + root.gain-sheet-max-lane + " (1-based). Gain in dB, -40 to +40. Unity = 0 dB."
                                    : "No audio lanes — add one first.";
                                color: #888;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 10px;
                                VerticalBox {
                                    spacing: 4px;
                                    Text {
                                        text: "Lane";
                                        color: #bbb;
                                        font-size: 11px;
                                    }
                                    gain-lane-input := LineEdit {
                                        text: root.gain-sheet-lane;
                                        input-type: number;
                                        edited(t) => {
                                            root.gain-lane-changed(t.to-float());
                                        }
                                    }
                                }
                                VerticalBox {
                                    spacing: 4px;
                                    Text {
                                        text: "Gain (dB)";
                                        color: #bbb;
                                        font-size: 11px;
                                    }
                                    gain-db-input := LineEdit {
                                        text: round(root.gain-sheet-db * 10) / 10;
                                        input-type: decimal;
                                    }
                                }
                            }
                            if root.gain-sheet-error != "": Text {
                                text: root.gain-sheet-error;
                                color: #ff8080;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 10px;
                                alignment: end;
                                Button {
                                    text: "Cancel";
                                    clicked => {
                                        root.gain-cancel();
                                    }
                                }
                                Button {
                                    text: "Set Gain";
                                    primary: true;
                                    clicked => {
                                        root.gain-confirm(
                                            gain-lane-input.text.to-float(),
                                            gain-db-input.text.to-float(),
                                        );
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.resize-sheet-visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: rgba(0, 0, 0, 55%);
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.resize-cancel();
                }
            }
            VerticalBox {
                alignment: center;
                vertical-stretch: 1;
                horizontal-stretch: 1;
                HorizontalBox {
                    alignment: center;
                    horizontal-stretch: 1;
                    Rectangle {
                        width: min(parent.width * 0.92, 440px);
                        background: #2e2e36;
                        border-radius: 8px;
                        TouchArea {
                            // Swallow clicks inside the card so the backdrop doesn't close the sheet.
                            width: 100%;
                            height: 100%;
                        }
                        VerticalBox {
                            padding: 16px;
                            spacing: 10px;
                            Text {
                                text: "Resize Video";
                                color: #eee;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            Text {
                                text: root.resize-source-width > 0 && root.resize-source-height > 0
                                    ? "Source: " + root.resize-source-width + "×" + root.resize-source-height + " px. Scale applies to export only (preview is unchanged)."
                                    : "Scale applies to export only (preview is unchanged).";
                                color: #888;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 6px;
                                alignment: center;
                                Button {
                                    text: "25%";
                                    clicked => { resize-input.text = "25"; }
                                }
                                Button {
                                    text: "50%";
                                    clicked => { resize-input.text = "50"; }
                                }
                                Button {
                                    text: "75%";
                                    clicked => { resize-input.text = "75"; }
                                }
                                Button {
                                    text: "100%";
                                    clicked => { resize-input.text = "100"; }
                                }
                                Button {
                                    text: "150%";
                                    clicked => { resize-input.text = "150"; }
                                }
                                Button {
                                    text: "200%";
                                    clicked => { resize-input.text = "200"; }
                                }
                            }
                            VerticalBox {
                                spacing: 4px;
                                Text {
                                    text: "Scale (%) — range 10–400";
                                    color: #bbb;
                                    font-size: 11px;
                                }
                                resize-input := LineEdit {
                                    text: root.resize-percent;
                                    input-type: number;
                                }
                            }
                            if root.resize-error != "": Text {
                                text: root.resize-error;
                                color: #ff8080;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                spacing: 10px;
                                alignment: end;
                                Button {
                                    text: "Cancel";
                                    clicked => {
                                        root.resize-cancel();
                                    }
                                }
                                Button {
                                    text: "Resize";
                                    primary: true;
                                    clicked => {
                                        root.resize-confirm(round(resize-input.text.to-float()));
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
