import { HelpWindow } from "help_window.slint";
import { Button, HorizontalBox, Slider, VerticalBox } from "std-widgets.slint";

export { HelpWindow }

export component AppWindow inherits Window {
    preferred-width: 960px;
    preferred-height: 600px;
    title: "Reel";

    // Video fit: 0 = contain (fit), 1 = cover (fill)
    in-out property <int> video-fit-mode: 0;
    in-out property <bool> stay-on-top: false;

    always-on-top: root.stay-on-top;

    in property <image> current-frame;
    in property <float> duration-ms: 0;
    in property <float> playhead-ms: 0;
    in property <bool> is-playing: false;
    in property <bool> media-ready: false;
    in property <string> status-text: "Ready";

    in property <bool> close-enabled: false;
    in property <bool> revert-enabled: false;
    in property <bool> save-enabled: false;
    in property <bool> undo-enabled: false;
    in property <bool> redo-enabled: false;
    in property <bool> move-clip-down-enabled: false;
    in property <bool> move-clip-up-enabled: false;
    in property <bool> split-at-playhead-enabled: false;
    in property <bool> export-in-progress: false;

    /// Multi-track summary + preview rule (see session.timeline_summary_line).
    in property <string> timeline-info: "";
    /// One line per video track lane, newline-separated (see session.video_track_row_labels).
    in property <string> video-track-lanes: "";
    /// Playhead / duration (see `timecode::format_pair`).
    in property <string> timecode: "0:00.000 / 0:00.000";

    callback file-open();
    callback file-close();
    callback file-revert();
    callback file-new-window();
    callback file-save();
    callback file-insert-video();
    callback file-new-video-track();
    callback file-export();
    callback export-cancel();

    callback edit-undo();
    callback edit-redo();
    callback edit-split-at-playhead();
    callback edit-move-clip-down();
    callback edit-move-clip-up();

    callback effect-face-swap();
    callback effect-face-enhance();
    callback effect-remove-background();

    callback win-fit();
    callback win-fill();
    callback win-center();
    callback win-toggle-on-top();

    callback help-overview();
    callback help-features();
    callback help-keyboard();
    callback help-media-formats();
    callback help-supported-formats();
    callback help-cli();
    callback help-external-ai();
    callback help-developers();
    callback help-agents();
    callback help-phases-ui();

    callback play-pause();
    callback seek-timeline(float);
    /// Nudge playhead by delta milliseconds (e.g. ±1000 for arrow keys).
    callback seek-nudge-ms(float);

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Open…";
                activated => { root.file-open(); }
            }
            MenuItem {
                title: "Close";
                enabled: root.close-enabled;
                activated => { root.file-close(); }
            }
            MenuItem {
                title: "Revert";
                enabled: root.revert-enabled;
                activated => { root.file-revert(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "New Window";
                activated => { root.file-new-window(); }
            }
            MenuItem {
                title: "Save…";
                enabled: root.save-enabled;
                activated => { root.file-save(); }
            }
            MenuItem {
                title: "Insert Video…";
                activated => { root.file-insert-video(); }
            }
            MenuItem {
                title: "New Video Track";
                enabled: root.media-ready;
                activated => { root.file-new-video-track(); }
            }
            MenuItem {
                title: "Export…";
                enabled: root.media-ready && !root.export-in-progress;
                activated => { root.file-export(); }
            }
            MenuItem {
                title: "Cancel Export";
                enabled: root.export-in-progress;
                activated => { root.export-cancel(); }
            }
        }
        Menu {
            title: "Edit";
            MenuItem {
                title: "Undo";
                enabled: root.undo-enabled;
                activated => { root.edit-undo(); }
            }
            MenuItem {
                title: "Redo";
                enabled: root.redo-enabled;
                activated => { root.edit-redo(); }
            }
            MenuItem {
                title: "Split Clip at Playhead";
                enabled: root.split-at-playhead-enabled;
                activated => { root.edit-split-at-playhead(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Move Clip to Track Below";
                enabled: root.move-clip-down-enabled;
                activated => { root.edit-move-clip-down(); }
            }
            MenuItem {
                title: "Move Clip to Track Above";
                enabled: root.move-clip-up-enabled;
                activated => { root.edit-move-clip-up(); }
            }
        }
        Menu {
            title: "Effects";
            MenuItem {
                title: "Face Swap (FaceFusion)…";
                enabled: root.media-ready;
                activated => { root.effect-face-swap(); }
            }
            MenuItem {
                title: "Face Enhance…";
                enabled: root.media-ready;
                activated => { root.effect-face-enhance(); }
            }
            MenuItem {
                title: "Remove Background (RVM-style)…";
                enabled: root.media-ready;
                activated => { root.effect-remove-background(); }
            }
        }
        Menu {
            title: "Window";
            MenuItem {
                title: "Always on Top";
                activated => { root.win-toggle-on-top(); }
            }
            MenuSeparator { }
            MenuItem {
                title: "Fit";
                activated => { root.win-fit(); }
            }
            MenuItem {
                title: "Fill";
                activated => { root.win-fill(); }
            }
            MenuItem {
                title: "Center";
                activated => { root.win-center(); }
            }
        }
        Menu {
            title: "Help";
            MenuItem {
                title: "Overview";
                activated => { root.help-overview(); }
            }
            MenuItem {
                title: "Features & roadmap";
                activated => { root.help-features(); }
            }
            MenuItem {
                title: "Keyboard shortcuts";
                activated => { root.help-keyboard(); }
            }
            MenuItem {
                title: "Media formats & tracks";
                activated => { root.help-media-formats(); }
            }
            MenuItem {
                title: "Supported formats (playback vs export)";
                activated => { root.help-supported-formats(); }
            }
            MenuItem {
                title: "CLI (reel-cli)";
                activated => { root.help-cli(); }
            }
            MenuItem {
                title: "External AI & tools";
                activated => { root.help-external-ai(); }
            }
            MenuItem {
                title: "Developers";
                activated => { root.help-developers(); }
            }
            MenuItem {
                title: "Agent guide (Cursor / Claude)";
                activated => { root.help-agents(); }
            }
            MenuItem {
                title: "UI phases roadmap";
                activated => { root.help-phases-ui(); }
            }
        }
    }

    FocusScope {
        vertical-stretch: 1;
        width: 100%;
        focus-on-click: true;
        key-pressed(event) => {
            // File: Open / Save work without media (e.g. empty window — Open a project).
            if (event.text == Key.O && event.modifiers.control && !event.modifiers.shift) {
                root.file-open();
                accept
            } else if (event.text == Key.S && event.modifiers.control && !event.modifiers.shift) {
                if (root.save-enabled) {
                    root.file-save();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.W && event.modifiers.control && !event.modifiers.shift) {
                if (root.close-enabled) {
                    root.file-close();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.F1) {
                root.help-overview();
                accept
            } else if (event.text == Key.Escape) {
                if (root.export-in-progress) {
                    root.export-cancel();
                    accept
                } else {
                    reject
                }
            } else if (!root.media-ready) {
                reject
            } else if (event.text == Key.N && event.modifiers.control && event.modifiers.shift) {
                root.file-new-video-track();
                accept
            } else if (event.text == Key.I && event.modifiers.control && !event.modifiers.shift) {
                root.file-insert-video();
                accept
            } else if (event.text == Key.E && event.modifiers.control && !event.modifiers.shift) {
                if (!root.export-in-progress) {
                    root.file-export();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.Space) {
                root.play-pause();
                accept
            } else if (event.text == Key.LeftArrow) {
                root.seek-nudge-ms(-1000.0);
                accept
            } else if (event.text == Key.RightArrow) {
                root.seek-nudge-ms(1000.0);
                accept
            } else if (event.text == Key.Home) {
                root.seek-timeline(0.0);
                accept
            } else if (event.text == Key.End) {
                root.seek-timeline(root.duration-ms);
                accept
            } else if (event.text == Key.Z && event.modifiers.control && event.modifiers.shift) {
                if (root.redo-enabled) {
                    root.edit-redo();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.Z && event.modifiers.control && !event.modifiers.shift) {
                if (root.undo-enabled) {
                    root.edit-undo();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.B && event.modifiers.control && !event.modifiers.shift) {
                if (root.split-at-playhead-enabled) {
                    root.edit-split-at-playhead();
                    accept
                } else {
                    reject
                }
            // Ctrl+Shift+Arrow: move clip (⌘⇧ on macOS — Slint maps Command to `control`).
            } else if (event.text == Key.DownArrow && event.modifiers.control && event.modifiers.shift) {
                if (root.move-clip-down-enabled) {
                    root.edit-move-clip-down();
                    accept
                } else {
                    reject
                }
            } else if (event.text == Key.UpArrow && event.modifiers.control && event.modifiers.shift) {
                if (root.move-clip-up-enabled) {
                    root.edit-move-clip-up();
                    accept
                } else {
                    reject
                }
            } else {
                reject
            }
        }
        VerticalBox {
        spacing: 0px;
        padding: 0px;

        Rectangle {
            background: #000;
            vertical-stretch: 1;
            Image {
                source: root.current-frame;
                image-fit: root.video-fit-mode == 1 ? cover : contain;
                width: parent.width;
                height: parent.height;
            }
        }

        Rectangle {
            background: #1a1a20;
            min-height: 92px;
            vertical-stretch: 0;
            VerticalBox {
                padding: 8px;
                spacing: 4px;
                HorizontalBox {
                    Text {
                        text: "Timeline";
                        color: #888;
                        font-size: 11px;
                        horizontal-stretch: 0;
                    }
                    Text {
                        text: root.timecode;
                        color: #aaa;
                        font-size: 11px;
                        horizontal-alignment: right;
                        horizontal-stretch: 1;
                    }
                }
                Text {
                    text: root.timeline-info;
                    color: #666;
                    font-size: 10px;
                    wrap: word-wrap;
                    visible: root.timeline-info != "";
                }
                Text {
                    text: root.video-track-lanes;
                    color: #8a8a95;
                    font-size: 10px;
                    wrap: word-wrap;
                    visible: root.video-track-lanes != "";
                }
                Slider {
                    enabled: root.media-ready;
                    minimum: 0;
                    maximum: max(root.duration-ms, 1);
                    value: root.playhead-ms;
                    changed(v) => {
                        root.seek-timeline(v);
                    }
                    height: 28px;
                }
            }
        }

        Rectangle {
            background: #2a2a30;
            height: 52px;
            HorizontalBox {
                padding: 8px;
                spacing: 12px;
                alignment: center;

                Button {
                    text: root.is-playing ? "Pause" : "Play";
                    enabled: root.media-ready;
                    clicked => { root.play-pause(); }
                }
                Text {
                    text: root.status-text;
                    color: #ccc;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }
    }
    }
}
